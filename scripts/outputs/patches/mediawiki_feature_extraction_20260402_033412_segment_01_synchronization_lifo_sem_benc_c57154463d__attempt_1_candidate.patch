+static void contendedUse_ipc_v1(uint32_t n, int posters, int waiters) {
+  LifoSemImpl<std::atomic> sem;
+
+  std::vector<std::thread> threads;
+  std::atomic<bool> go(false);
+
+  BENCHMARK_SUSPEND {
+    for (int t = 0; t < waiters; ++t) {
+      threads.emplace_back([=, &sem] {
+        for (uint32_t i = t; i < n; i += waiters) {
+          sem.wait();
+        }
+      });
+    }
+    for (int t = 0; t < posters; ++t) {
+      threads.emplace_back([=, &sem, &go] {
+        ChainNode* l1HotPos = &l1HotNodes[t % kL1HotLen];
+        uint64_t acc = t;
+
+        while (!go.load()) {
+          std::this_thread::yield();
+        }
+        for (uint32_t i = t; i < n; i += posters) {
+          l1HotPos = l1HotPos->next;
+          acc += (uint64_t)(uintptr_t)l1HotPos;
+          acc = (acc * 17) ^ (acc >> 13);
+          *(uint64_t*)l1HotPos->pad = acc;
+
+          sem.post();
+        }
+        folly::doNotOptimizeAway(l1HotPos);
+        folly::doNotOptimizeAway(acc);
+      });
+    }
+  }
+
+  go.store(true);
+  for (auto& thr : threads) {
+    thr.join();
+  }
+}
 
