+namespace {
+
+struct ChainNode {
+  ChainNode* next;
+  char pad[64 - sizeof(ChainNode*)];
+};
+
+// Hot chain: 1 MB
+constexpr size_t kHotLen = 16384; // 16384 * 64B = 1MB
+ChainNode hotNodes[kHotLen];
+
+// Cold chain: 128 MB
+constexpr size_t kColdLen = 2 * 1024 * 1024; // 2M nodes * 64B = 128MB
+ChainNode* coldNodes = nullptr;
+
+void initChain(ChainNode* nodes, size_t len) {
+  std::vector<size_t> perm(len);
+  std::iota(perm.begin(), perm.end(), 0u);
+  std::mt19937_64 rng(42);
+  for (size_t i = len - 1; i > 0; --i) {
+    std::swap(perm[i], perm[rng() % (i + 1)]);
+  }
+  for (size_t i = 0; i < len; ++i) {
+    nodes[perm[i]].next = &nodes[perm[(i + 1) % len]];
+  }
+}
+
+#define SWITCH_CASE_IMPL_A(i, v) \
+  case i: \
+    v = (v << 1) + i; \
+    v ^= 0xdeadbeef12345678; \
+    break;
+#define SWITCH_CASE_IMPL_B(i, v) \
+  case i: \
+    v = (v >> 1) ^ i; \
+    v += 0xfaceb00c87654321; \
+    break;
+#define SWITCH_CASE_IMPL_C(i, v) \
+  case i: \
+    v = (v * 31) + i; \
+    v = ~v; \
+    break;
+
+#define SWITCH_CASES_16(start, v, impl) \
+  impl(start + 0, v) \
+  impl(start + 1, v) \
+  impl(start + 2, v) \
+  impl(start + 3, v) \
+  impl(start + 4, v) \
+  impl(start + 5, v) \
+  impl(start + 6, v) \
+  impl(start + 7, v) \
+  impl(start + 8, v) \
+  impl(start + 9, v) \
+  impl(start + 10, v) \
+  impl(start + 11, v) \
+  impl(start + 12, v) \
+  impl(start + 13, v) \
+  impl(start + 14, v) \
+  impl(start + 15, v)
+
+#define SWITCH_CASES_256(v, impl) \
+  SWITCH_CASES_16(0, v, impl) \
+  SWITCH_CASES_16(16, v, impl) \
+  SWITCH_CASES_16(32, v, impl) \
+  SWITCH_CASES_16(48, v, impl) \
+  SWITCH_CASES_16(64, v, impl) \
+  SWITCH_CASES_16(80, v, impl) \
+  SWITCH_CASES_16(96, v, impl) \
+  SWITCH_CASES_16(112, v, impl) \
+  SWITCH_CASES_16(128, v, impl) \
+  SWITCH_CASES_16(144, v, impl) \
+  SWITCH_CASES_16(160, v, impl) \
+  SWITCH_CASES_16(176, v, impl) \
+  SWITCH_CASES_16(192, v, impl) \
+  SWITCH_CASES_16(208, v, impl) \
+  SWITCH_CASES_16(224, v, impl) \
+  SWITCH_CASES_16(240, v, impl)
+
+__attribute__((noinline)) uint64_t switchA(uint64_t v, int c) {
+  switch (c) {
+    SWITCH_CASES_256(v, SWITCH_CASE_IMPL_A)
+  }
+  return v;
+}
+
+__attribute__((noinline)) uint64_t switchB(uint64_t v, int c) {
+  switch (c) {
+    SWITCH_CASES_256(v, SWITCH_CASE_IMPL_B)
+  }
+  return v;
+}
+
+__attribute__((noinline)) uint64_t switchC(uint64_t v, int c) {
+  switch (c) {
+    SWITCH_CASES_256(v, SWITCH_CASE_IMPL_C)
+  }
+  return v;
+}
+
+std::once_flag chains_initialized;
+
+void initialize_chains() {
+  std::call_once(chains_initialized, [] {
+    initChain(hotNodes, kHotLen);
+    if (!coldNodes) {
+      coldNodes = new ChainNode[kColdLen];
+      initChain(coldNodes, kColdLen);
+    }
+  });
+}
+} // namespace
 
