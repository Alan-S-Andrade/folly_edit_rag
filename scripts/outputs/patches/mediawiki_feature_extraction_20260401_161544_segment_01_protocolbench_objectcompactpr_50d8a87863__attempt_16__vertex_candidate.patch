+        break;
+    }
+    return val;
+}
+
+__attribute__((noinline))
+int L1i_switch_func_1(int x, int y) {
+    int val = y;
+    switch (x & 0xFF) {
+    G(256 * 28)
+    default:
+        break;
+    }
+    return val;
+}
+
+__attribute__((noinline))
+int L1i_switch_func_2(int x, int y) {
