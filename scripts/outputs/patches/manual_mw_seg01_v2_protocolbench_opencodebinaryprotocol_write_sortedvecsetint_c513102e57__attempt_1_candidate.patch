+__attribute__((noinline)) int icache_churn_0(int x, int y) {
+  int acc = y;
+  switch (x) {
+#define CASE_BLOCK(i, p1, p2, p3, p4)                                     \
+  case i:                                                                \
+    acc = (acc * (i * 3 + p1)) ^ (acc + (i * 5 + p2));                    \
+    acc = (acc * (i * 7 + p1 + 2)) + (acc ^ (i * 11 + p2 + 4));           \
+    acc = (acc * (i * 13 + p1 + 6)) ^ (acc + (i * 17 + p2 + 6));          \
+    acc = (acc * (i * 19 + p1 + 8)) + (acc ^ (i * 23 + p3));              \
+    acc = (acc * (i * 29 + p1 + 10)) ^ (acc + (i * 31 + p3 + 2));         \
+    acc = (acc * (i * 37 + p1 + 12)) + (acc ^ (i * 41 + p4));             \
+    acc = (acc * (i * 43 + p1 + 14)) ^ (acc + (i * 47 + p4 + 4));         \
+    break;
+#define C1(i, ...) CASE_BLOCK(i, __VA_ARGS__)
+#define C2(i, ...) \
+  C1(i, __VA_ARGS__) \
+  C1(i + 1, __VA_ARGS__)
+#define C4(i, ...) \
+  C2(i, __VA_ARGS__) \
+  C2(i + 2, __VA_ARGS__)
+#define C8(i, ...) \
+  C4(i, __VA_ARGS__) \
+  C4(i + 4, __VA_ARGS__)
+#define C16(i, ...) \
+  C8(i, __VA_ARGS__) \
+  C8(i + 8, __VA_ARGS__)
+#define C32(i, ...) \
+  C16(i, __VA_ARGS__) \
+  C16(i + 16, __VA_ARGS__)
+#define C64(i, ...) \
+  C32(i, __VA_ARGS__) \
+  C32(i + 32, __VA_ARGS__)
+#define C128(i, ...) \
+  C64(i, __VA_ARGS__) \
+  C64(i + 64, __VA_ARGS__)
+#define C256(i, ...) \
+  C128(i, __VA_ARGS__) \
+  C128(i + 128, __VA_ARGS__)
+    C256(0, 101, 13, 19, 37)
+#undef CASE_BLOCK
+#undef C1
+#undef C2
+#undef C4
+#undef C8
+#undef C16
+#undef C32
+#undef C64
+#undef C128
+#undef C256
+  }
+  return acc;
+}
