+BENCHMARK(SimpleJSONProtocol_read_UnorderedSetInt_FrontendPressure, iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<UnorderedSetInt>();
+  folly::IOBufQueue q;
+  SimpleJSONSerializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+
+  // Build a pointer-chase chain of 256 nodes so the switch index comes from
+  // an unpredictable load, preventing the compiler from optimising the switch.
+  constexpr int kChainLen = 256;
+  std::vector<uint64_t> chain(kChainLen);
+  for (int i = 0; i < kChainLen; ++i) {
+    // Each node's low byte encodes the next node index (wrapping).
+    chain[i] = static_cast<uint64_t>((i * 137 + 13) & 0xFF) |
+        (static_cast<uint64_t>((i * 53 + 7) & 0xFF) << 8);
+  }
+  susp.dismiss();
+
+  uint64_t acc = 1;
+  uint64_t chainIdx = 0;
+  size_t j = 0;
+  while (iters--) {
+    // Deserialize (the primary work matching the original benchmark).
+    UnorderedSetInt data;
+    SimpleJSONSerializer::deserialize(buf.get(), data);
+    folly::doNotOptimizeAway(data);
+
+    // Frontend-pressure epilogue: pointer-chase -> switch dispatch, 8 times.
+    for (int k = 0; k < 8; ++k) {
+      uint8_t idx = static_cast<uint8_t>(chain[chainIdx & 0xFF]);
+      chainIdx = chain[chainIdx & 0xFF] >> 8;
+      switch (j % 3) {
+        case 0: acc = switchFrontendA(idx, acc); break;
+        case 1: acc = switchFrontendB(idx, acc); break;
+        default: acc = switchFrontendC(idx, acc); break;
+      }
+      ++j;
+    }
+  }
+  folly::doNotOptimizeAway(acc);
+}
