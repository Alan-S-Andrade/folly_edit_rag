+// These functions are designed to increase I-cache misses.
+// Each function has a large switch statement. By rotating through them,
+// we can increase the hot code footprint.
+
+// To prevent compiler from optimizing away, and to make functions different.
+__attribute__((noinline))
+int icache_miss_func_1(int x, const uint8_t* p) {
+  int res = x;
+  // Each case needs unique constants to prevent deduplication
+#define ALU_OP(i, C) res = (res * 3) ^ (p[i] + C);
+#define CASE_BLOCK(i, C) \
+  case i:                \
+    ALU_OP(1, C + 1)     \
+    ALU_OP(2, C + 2)     \
+    ALU_OP(3, C + 3)     \
+    ALU_OP(4, C + 4)     \
+    ALU_OP(5, C + 5)     \
+    ALU_OP(6, C + 6)     \
+    ALU_OP(7, C + 7)     \
+    ALU_OP(8, C + 8)     \
+    ALU_OP(9, C + 9) break;
+
+  switch (p[0]) {
+#define CASES_16(i, C)   \
+  CASE_BLOCK(i + 0, C + 0)   \
+  CASE_BLOCK(i + 1, C + 1)   \
+  CASE_BLOCK(i + 2, C + 2)   \
+  CASE_BLOCK(i + 3, C + 3)   \
+  CASE_BLOCK(i + 4, C + 4)   \
+  CASE_BLOCK(i + 5, C + 5)   \
+  CASE_BLOCK(i + 6, C + 6)   \
+  CASE_BLOCK(i + 7, C + 7)   \
+  CASE_BLOCK(i + 8, C + 8)   \
+  CASE_BLOCK(i + 9, C + 9)   \
+  CASE_BLOCK(i + 10, C + 10) \
+  CASE_BLOCK(i + 11, C + 11) \
+  CASE_BLOCK(i + 12, C + 12) \
+  CASE_BLOCK(i + 13, C + 13) \
+  CASE_BLOCK(i + 14, C + 14) \
+  CASE_BLOCK(i + 15, C + 15)
+
+    CASES_16(0, 0x1000) CASES_16(16, 0x1100) CASES_16(32, 0x1200)
+        CASES_16(48, 0x1300) CASES_16(64, 0x1400) CASES_16(80, 0x1500)
+            CASES_16(96, 0x1600) CASES_16(112, 0x1700) CASES_16(128, 0x1800)
+                CASES_16(144, 0x1900) CASES_16(160, 0x1A00) CASES_16(176, 0x1B00)
+                    CASES_16(192, 0x1C00) CASES_16(208, 0x1D00)
+                        CASES_16(224, 0x1E00) CASES_16(240, 0x1F00)
+
+#undef CASES_16
+#undef CASE_BLOCK
+#undef ALU_OP
+  }
+  return res;
+}
