+__attribute__((noinline)) uint64_t switchA_v2(uint64_t v, int c) {
+  switch (c) {
+    CASES_256_t1f_ops(v, c);
+    default:;
+  }
+  return v;
+}
+__attribute__((noinline)) uint64_t switchB_v2(uint64_t v, int c) {
+  switch (c) {
+    CASES_256_t1f_ops(v, c * 3);
+    default:;
+  }
+  return v;
+}
+__attribute__((noinline)) uint64_t switchC_v2(uint64_t v, int c) {
+  switch (c) {
+    CASES_256_t1f_ops(v, c * 5);
+    default:;
+  }
+  return v;
+}
