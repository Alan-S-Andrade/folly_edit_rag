+// New derived benchmark using the PROVEN PATTERN
+BENCHMARK(createAndDestroyMulti_IndirectBranch, iters) {
+  static constexpr auto kSize = 1024;
+  static constexpr size_t kChainLen = 100; // Tune this value for branch misprediction
+  std::array<std::unique_ptr<IOBuf>, kSize> buffers;
+  uint8_t val = 0;
+
+  while (iters--) {
+    for (size_t i = 0; i < kSize; ++i) {
+      buffers[i] = IOBuf::create(128); // Small size to focus on control flow
+      val = chain_func(val + (i & 0x01), kChainLen);
+      folly::doNotOptimizeAway(buffers[i]->capacity());
+    }
+    folly::doNotOptimizeAway(val);
+  }
+}
