+namespace {
+// Helper functions for the PROVEN PATTERN
+inline void case_func(uint8_t v) {
+  // Use a switch statement with a large number of cases to promote branch mispredictions.
+  // The index is derived from a value that is unlikely to be predictable by the CPU.
+  switch (v % 3) {
+    case 0:
+      folly::doNotOptimizeAway(v);
+      break;
+    case 1:
+      folly::doNotOptimizeAway(v);
+      break;
+    case 2:
+      folly::doNotOptimizeAway(v);
+      break;
+  }
+}
+
+// Function to generate a chain of indirect branches
+inline uint8_t chain_func(uint8_t v, size_t chainLen) {
+  if (chainLen == 0) {
+    return v;
+  }
+  // Introduce a level of indirection by using a pointer to a function.
+  // The function pointer is calculated based on the input value, making it less predictable.
+  case_func(v);
+  return chain_func(v + (v & 0x01), chainLen - 1);
+}
+} // namespace
