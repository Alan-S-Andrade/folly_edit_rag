 X(, SimpleJSON)
+
+BENCHMARK(SimpleJSONProtocol_read_UnorderedSetInt_smaller, iters) {
+  folly::BenchmarkSuspender susp;
+  UnorderedSetInt strct;
+  constexpr int kSize = 25;
+  strct.ints_ref()->reserve(kSize);
+  for (size_t i = 0; i < kSize; ++i) {
+    strct.ints_ref()->insert(folly::hash::twang_mix64(i));
+  }
+  folly::IOBufQueue q;
+  SimpleJSONSerializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+  susp.dismiss();
+
+  while (iters--) {
+    UnorderedSetInt data;
+    SimpleJSONSerializer::deserialize(buf.get(), data);
+    folly::doNotOptimizeAway(data);
+  }
+  susp.rehire();
+}
+
 X(, JSON)
 X(, Frozen)
 X(Object, Binary)
