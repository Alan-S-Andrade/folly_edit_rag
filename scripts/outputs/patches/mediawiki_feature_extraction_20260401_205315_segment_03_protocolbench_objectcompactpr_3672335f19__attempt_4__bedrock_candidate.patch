+template <
+    SerializerMethod kSerializerMethod,
+    typename Serializer,
+    typename Struct>
+void readBenchMultiBuffer(size_t iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<Struct>();
+  folly::IOBufQueue q;
+  Serializer::serialize(strct, &q);
+  auto buf = q.move();
+  // Do NOT coalesce - keep the IOBuf chain fragmented to stress memory
+  // access patterns and increase cache pressure, lowering IPC.
+  susp.dismiss();
+
+  while (iters--) {
+    if constexpr (kSerializerMethod == SerializerMethod::Object) {
+      // Clone so each iteration works on the original fragmented chain
+      auto clone = buf->clone();
+      auto obj = protocol::parseObject<GetReader<Serializer>>(*clone);
+      folly::doNotOptimizeAway(obj);
+    } else {
+      auto clone = buf->clone();
+      Struct data;
+      Serializer::deserialize(clone.get(), data);
       folly::doNotOptimizeAway(data);
     }
   }
