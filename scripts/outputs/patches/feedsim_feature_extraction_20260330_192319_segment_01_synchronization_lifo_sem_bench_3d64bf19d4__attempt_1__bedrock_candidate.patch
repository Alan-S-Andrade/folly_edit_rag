+__attribute__((noinline)) uint64_t chaseSwB(uint64_t v, int c) {
+  switch (c & 0xFF) {
+    case 0: v -= 0x1a2b3c4dULL; v ^= 0xf5e6d7c8ULL; break;
+    case 1: v += 0xb9a89786ULL; v *= 0x75645342ULL; break;
+    case 2: v ^= 0x31201f0eULL; v += 0xfdfcfbfaULL; break;
+    case 3: v -= 0xf9e8d7c6ULL; v ^= 0xb5a49382ULL; break;
+    case 4: v += 0x71605f4eULL; v *= 0x3d2c1b0aULL; break;
+    case 5: v ^= 0xf9e8d700ULL; v -= 0xc6b5a493ULL; break;
+    case 6: v -= 0x82716050ULL; v ^= 0x4f3e2d1cULL; break;
+    case 7: v += 0x0b1a2938ULL; v *= 0x4756657aULL; break;
+    case 8: v ^= 0x8990a1b2ULL; v += 0xc3d4e5f6ULL; break;
+    case 9: v -= 0x07182930ULL; v ^= 0x4a5b6c7dULL; break;
+    case 10: v += 0x8e9fa0b1ULL; v *= 0xc2d3e4f5ULL; break;
+    case 11: v ^= 0x06172839ULL; v -= 0x4a5b6c7dULL; break;
+    case 12: v -= 0x8e9fa0b0ULL; v ^= 0xc1d2e3f4ULL; break;
+    case 13: v += 0x05162738ULL; v *= 0x495a6b7cULL; break;
+    case 14: v ^= 0x8d9eafb0ULL; v += 0xc0d1e2f3ULL; break;
+    case 15: v -= 0x04152637ULL; v ^= 0x48596a7bULL; break;
+    case 16: v += 0x8c9daebfULL; v *= 0xbfd0e1f2ULL; break;
+    case 17: v ^= 0x03142536ULL; v -= 0x47586978ULL; break;
+    case 18: v -= 0x8b9cadbfULL; v ^= 0xbecfd0e1ULL; break;
+    case 19: v += 0x02132435ULL; v *= 0x46576879ULL; break;
+    case 20: v ^= 0x8a9bacbdULL; v += 0xbdcedfe0ULL; break;
+    case 21: v -= 0x01122334ULL; v ^= 0x45566778ULL; break;
+    case 22: v += 0x89aabbccULL; v *= 0xbccddeefULL; break;
+    case 23: v ^= 0x00112233ULL; v -= 0x44556677ULL; break;
+    case 24: v -= 0x8899aabbULL; v ^= 0xbbccddeaULL; break;
+    case 25: v += 0xff001122ULL; v *= 0x43546576ULL; break;
+    case 26: v ^= 0x8798a9baULL; v += 0xbacbd9e8ULL; break;
+    case 27: v -= 0xfeff0011ULL; v ^= 0x42536475ULL; break;
+    case 28: v += 0x8697a8b9ULL; v *= 0xb9cad8e7ULL; break;
+    case 29: v ^= 0xfdfeff00ULL; v -= 0x41526374ULL; break;
+    case 30: v -= 0x8596a7b8ULL; v ^= 0xb8c9d7e6ULL; break;
+    case 31: v += 0xfcfeff01ULL; v *= 0x40516273ULL; break;
+    default: v ^= (uint64_t)c * 0x6c62272e07bb0142ULL; break;
+  }
+  return v;
+}
