+__attribute__((noinline)) uint64_t chaseSwC(uint64_t v, int c) {
+  switch (c & 0xFF) {
+    case 0: v ^= 0x0f1e2d3cULL; v += 0x4b5a6978ULL; break;
+    case 1: v -= 0x8796a5b4ULL; v ^= 0xc3d2e1f0ULL; break;
+    case 2: v *= 0x0f1e2d40ULL; v -= 0x4b5a6978ULL; break;
+    case 3: v += 0x8796a5b5ULL; v ^= 0xc3d2e1f1ULL; break;
+    case 4: v ^= 0x0f1e2d41ULL; v -= 0x4b5a6979ULL; break;
+    case 5: v *= 0x8796a5b6ULL; v += 0xc3d2e1f2ULL; break;
+    case 6: v -= 0x0f1e2d42ULL; v ^= 0x4b5a697aULL; break;
+    case 7: v += 0x8796a5b7ULL; v *= 0xc3d2e1f3ULL; break;
+    case 8: v ^= 0x0f1e2d43ULL; v += 0x4b5a697bULL; break;
+    case 9: v -= 0x8796a5b8ULL; v ^= 0xc3d2e1f4ULL; break;
+    case 10: v *= 0x0f1e2d44ULL; v -= 0x4b5a697cULL; break;
+    case 11: v += 0x8796a5b9ULL; v ^= 0xc3d2e1f5ULL; break;
+    case 12: v ^= 0x0f1e2d45ULL; v -= 0x4b5a697dULL; break;
+    case 13: v *= 0x8796a5baULL; v += 0xc3d2e1f6ULL; break;
+    case 14: v -= 0x0f1e2d46ULL; v ^= 0x4b5a697eULL; break;
+    case 15: v += 0x8796a5bbULL; v *= 0xc3d2e1f7ULL; break;
+    case 16: v ^= 0x0f1e2d47ULL; v += 0x4b5a697fULL; break;
+    case 17: v -= 0x8796a5bcULL; v ^= 0xc3d2e1f8ULL; break;
+    case 18: v *= 0x0f1e2d48ULL; v -= 0x4b5a6980ULL; break;
+    case 19: v += 0x8796a5bdULL; v ^= 0xc3d2e1f9ULL; break;
+    case 20: v ^= 0x0f1e2d49ULL; v -= 0x4b5a6981ULL; break;
+    case 21: v *= 0x8796a5beULL; v += 0xc3d2e1faULL; break;
+    case 22: v -= 0x0f1e2d4aULL; v ^= 0x4b5a6982ULL; break;
+    case 23: v += 0x8796a5bfULL; v *= 0xc3d2e1fbULL; break;
+    case 24: v ^= 0x0f1e2d4bULL; v += 0x4b5a6983ULL; break;
+    case 25: v -= 0x8796a5c0ULL; v ^= 0xc3d2e1fcULL; break;
+    case 26: v *= 0x0f1e2d4cULL; v -= 0x4b5a6984ULL; break;
+    case 27: v += 0x8796a5c1ULL; v ^= 0xc3d2e1fdULL; break;
+    case 28: v ^= 0x0f1e2d4dULL; v -= 0x4b5a6985ULL; break;
+    case 29: v *= 0x8796a5c2ULL; v += 0xc3d2e1feULL; break;
+    case 30: v -= 0x0f1e2d4eULL; v ^= 0x4b5a6986ULL; break;
+    case 31: v += 0x8796a5c3ULL; v *= 0xc3d2e1ffULL; break;
+    default: v -= (uint64_t)c * 0xbf58476d1ce4e5b9ULL; break;
+  }
+  return v;
+}
+
+static void contendedUse_chasing_impl(uint32_t n, int posters, int waiters) {
+  ensureChainsInit();
+
+  LifoSemImpl<std::atomic> sem;
+  std::vector<std::thread> threads;
+  std::atomic<bool> go(false);
+
+  static constexpr size_t kInnerIters = 512 * 1024;
+
+  BENCHMARK_SUSPEND {
+    for (int t = 0; t < waiters; ++t) {
+      threads.emplace_back([=, &sem] {
+        for (uint32_t i = t; i < n; i += waiters) {
+          sem.wait();
+        }
+      });
+    }
+    for (int t = 0; t < posters; ++t) {
+      threads.emplace_back([=, &sem, &go] {
+        while (!go.load()) {
+          std::this_thread::yield();
+        }
+        for (uint32_t i = t; i < n; i += posters) {
+          sem.post();
+        }
+      });
+    }
+  }
+
+  // Timed hot path: pointer-chase through hot chain + 3-way switch on payload
+  ChaseNode* hotPos0 = &hotNodes[0];
+  ChaseNode* hotPos1 = &hotNodes[kHotLen / 3];
+  ChaseNode* hotPos2 = &hotNodes[2 * kHotLen / 3];
+  ChaseNode* coldPos = &coldNodes[0];
+  uint64_t acc = 0;
+
+  for (size_t j = 0; j < kInnerIters; ++j) {
+    hotPos0 = hotPos0->next;
+    hotPos1 = hotPos1->next;
+    hotPos2 = hotPos2->next;
+
+    uint64_t payload0 = (uint64_t)(uintptr_t)hotPos0;
+    uint64_t payload1 = (uint64_t)(uintptr_t)hotPos1;
+    uint64_t payload2 = (uint64_t)(uintptr_t)hotPos2;
+
+    switch (j % 3) {
+      case 0: acc = chaseSwA(acc ^ payload0, (int)(payload1 & 0xFF)); break;
+      case 1: acc = chaseSwB(acc ^ payload1, (int)(payload2 & 0xFF)); break;
+      case 2: acc = chaseSwC(acc ^ payload2, (int)(payload0 & 0xFF)); break;
+    }
+
+    // Branchless cold chain access every 8 steps for LLC pressure
+    uint64_t coldMask = -(uint64_t)((j & 7) == 0);
+    coldPos = (ChaseNode*)(
+        ((uintptr_t)coldPos->next & coldMask) |
+        ((uintptr_t)coldPos & ~coldMask));
+  }
+
+  folly::doNotOptimizeAway(acc);
+  folly::doNotOptimizeAway(coldPos);
+
+  go.store(true);
+  for (auto& thr : threads) {
+    thr.join();
+  }
+}
