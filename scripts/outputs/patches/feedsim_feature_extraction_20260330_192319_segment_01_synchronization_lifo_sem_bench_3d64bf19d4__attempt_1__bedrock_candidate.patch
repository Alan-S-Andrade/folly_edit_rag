+// ---------------------------------------------------------------------------
+// Pointer-chase chain infrastructure for contendedUse_chasing variant
+// ---------------------------------------------------------------------------
+namespace {
+
+struct ChaseNode {
+  ChaseNode* next;
+  char pad[56]; // 64 bytes total
+};
+
+static constexpr size_t kHotLen = 16384; // 1 MB — exceeds L1d
+static ChaseNode hotNodes[kHotLen];
+
+static constexpr size_t kColdLen = 1u << 19; // 512K nodes = 32 MB
+static ChaseNode* coldNodes = nullptr;
+
+static void initChain(ChaseNode* nodes, size_t len) {
+  std::vector<size_t> perm(len);
+  std::iota(perm.begin(), perm.end(), 0u);
+  std::mt19937_64 rng(0xdeadbeefcafe1234ULL);
+  for (size_t i = len - 1; i > 0; --i) {
+    std::swap(perm[i], perm[rng() % (i + 1)]);
+  }
+  for (size_t i = 0; i < len; ++i) {
+    nodes[perm[i]].next = &nodes[perm[(i + 1) % len]];
+  }
+}
+
+static std::once_flag chainsInitFlag;
+
+static void ensureChainsInit() {
+  std::call_once(chainsInitFlag, [] {
+    initChain(hotNodes, kHotLen);
+    coldNodes = new ChaseNode[kColdLen];
+    initChain(coldNodes, kColdLen);
+  });
+}
+
+__attribute__((noinline)) uint64_t chaseSwA(uint64_t v, int c) {
+  switch (c & 0xFF) {
+    case 0: v += 0x1a2b3c4dULL; v ^= 0x5e6f7081ULL; break;
+    case 1: v *= 0x9b2c3d4eULL; v += 0xaf00b1c2ULL; break;
+    case 2: v ^= 0xc3d4e5f6ULL; v -= 0x07182930ULL; break;
+    case 3: v += 0x4a5b6c7dULL; v ^= 0x8e9fA0b1ULL; break;
+    case 4: v *= 0xB2C3d4e5ULL; v += 0xf6071829ULL; break;
+    case 5: v ^= 0x3a4b5c6dULL; v -= 0x7e8f9001ULL; break;
+    case 6: v += 0x1213141aULL; v ^= 0x2b3c4d5eULL; break;
+    case 7: v *= 0x6f708192ULL; v += 0xa3b4c5d6ULL; break;
+    case 8: v ^= 0xe7f80910ULL; v -= 0x21324354ULL; break;
+    case 9: v += 0x65768798ULL; v ^= 0xa9bAcBdCULL; break;
+    case 10: v *= 0xedfE0f10ULL; v += 0x21324344ULL; break;
+    case 11: v ^= 0x55667788ULL; v -= 0x99aAbBcCULL; break;
+    case 12: v += 0xdDeEfF00ULL; v ^= 0x11223344ULL; break;
+    case 13: v *= 0x55667788ULL; v += 0x99aAbBcCULL; break;
+    case 14: v ^= 0xdDeEfF00ULL; v -= 0x11223344ULL; break;
+    case 15: v += 0x55667700ULL; v ^= 0xaabbccddULL; break;
+    case 16: v *= 0xeeff0011ULL; v += 0x22334455ULL; break;
+    case 17: v ^= 0x66778899ULL; v -= 0xaabbccddULL; break;
+    case 18: v += 0xeeff0011ULL; v ^= 0x22334455ULL; break;
+    case 19: v *= 0x66778800ULL; v += 0x11223300ULL; break;
+    case 20: v ^= 0x44556677ULL; v -= 0x8899aabbULL; break;
+    case 21: v += 0xccddeeffULL; v ^= 0x00112233ULL; break;
+    case 22: v *= 0x44556600ULL; v += 0x77889900ULL; break;
+    case 23: v ^= 0xaabbccddULL; v -= 0xeeff0011ULL; break;
+    case 24: v += 0x22334455ULL; v ^= 0x66778899ULL; break;
+    case 25: v *= 0xaabbcc00ULL; v += 0xddeeff00ULL; break;
+    case 26: v ^= 0x11223344ULL; v -= 0x55667788ULL; break;
+    case 27: v += 0x99aabbccULL; v ^= 0xddeeff00ULL; break;
+    case 28: v *= 0x11220033ULL; v += 0x44556677ULL; break;
+    case 29: v ^= 0x8899aabbULL; v -= 0xccddeeffULL; break;
+    case 30: v += 0x00112233ULL; v ^= 0x44556677ULL; break;
+    case 31: v *= 0x8899aa00ULL; v += 0xbbccdd00ULL; break;
+    default: v += (uint64_t)c * 0x9e3779b97f4a7c15ULL; break;
+  }
+  return v;
+}
