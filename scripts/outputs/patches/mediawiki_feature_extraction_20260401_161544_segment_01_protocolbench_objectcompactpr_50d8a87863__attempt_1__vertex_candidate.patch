+// To increase I-cache pressure.
+// Based on a proven pattern to increase L1i MPKI.
+
+#define ALU_OP_CHUNK(var, c1, c2, c3, c4) \
+  var += c1;                             \
+  var ^= c2;                             \
+  var *= c3;                             \
+  var -= c4;
+
+#define ALU_OPS_28(var, offset) \
+  ALU_OP_CHUNK(var, offset + 1, offset + 2, offset + 3, offset + 4) \
+  ALU_OP_CHUNK(var, offset + 5, offset + 6, offset + 7, offset + 8) \
+  ALU_OP_CHUNK(var, offset + 9, offset + 10, offset + 11, offset + 12) \
+  ALU_OP_CHUNK(var, offset + 13, offset + 14, offset + 15, offset + 16) \
+  ALU_OP_CHUNK(var, offset + 17, offset + 18, offset + 19, offset + 20) \
+  ALU_OP_CHUNK(var, offset + 21, offset + 22, offset + 23, offset + 24) \
+  ALU_OP_CHUNK(var, offset + 25, offset + 26, offset + 27, offset + 28)
+
+#define CASE_GEN(i, var, base)      \
+  case i:                           \
+    ALU_OPS_28(var, base + i * 28); \
+    break;
+
+#define CASES_16(start, var, base) \
+  CASE_GEN(start + 0, var, base)   \
+  CASE_GEN(start + 1, var, base)   \
+  CASE_GEN(start + 2, var, base)   \
+  CASE_GEN(start + 3, var, base)   \
+  CASE_GEN(start + 4, var, base)   \
+  CASE_GEN(start + 5, var, base)   \
+  CASE_GEN(start + 6, var, base)   \
+  CASE_GEN(start + 7, var, base)   \
+  CASE_GEN(start + 8, var, base)   \
+  CASE_GEN(start + 9, var, base)   \
+  CASE_GEN(start + 10, var, base)  \
+  CASE_GEN(start + 11, var, base)  \
+  CASE_GEN(start + 12, var, base)  \
+  CASE_GEN(start + 13, var, base)  \
+  CASE_GEN(start + 14, var, base)  \
+  CASE_GEN(start + 15, var, base)
+
+#define CASES_256(var, base) \
+  CASES_16(0, var, base)     \
+  CASES_16(16, var, base)    \
+  CASES_16(32, var, base)    \
+  CASES_16(48, var, base)    \
+  CASES_16(64, var, base)    \
+  CASES_16(80, var, base)    \
+  CASES_16(96, var, base)    \
+  CASES_16(112, var, base)   \
+  CASES_16(128, var, base)   \
+  CASES_16(144, var, base)   \
+  CASES_16(160, var, base)   \
+  CASES_16(176, var, base)   \
+  CASES_16(192, var, base)   \
+  CASES_16(208, var, base)   \
+  CASES_16(224, var, base)   \
+  CASES_16(240, var, base)
+
+__attribute__((noinline)) int64_t L1i_switch_0(char payload) {
+  int64_t val = payload;
+  switch (static_cast<uint8_t>(payload)) {
+    CASES_256(val, 20000)
+  }
+  return val;
+}
+
+__attribute__((noinline)) int64_t L1i_switch_1(char payload) {
+  int64_t val = payload;
+  switch (static_cast<uint8_t>(payload)) {
+    CASES_256(val, 30000)
+  }
+  return val;
+}
+
+__attribute__((noinline)) int64_t L1i_switch_2(char payload) {
+  int64_t val = payload;
+  switch (static_cast<uint8_t>(payload)) {
+    CASES_256(val, 40000)
+  }
+  return val;
+}
