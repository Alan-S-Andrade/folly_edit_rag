+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_L1i, iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<thrift::benchmark::LargeSetInt>();
+  folly::IOBufQueue q;
+  apache::thrift::CompactSerializer::serialize(strct, &q);
+  auto buf = q.move();
+  // coalesce the IOBuf chain to test fast path
+  buf->coalesce();
+
+  constexpr size_t kChaseSize = 4096;
+  std::vector<ChaseNode> chase_nodes(kChaseSize);
+  for (size_t i = 0; i < kChaseSize; ++i) {
+    chase_nodes[i].next = &chase_nodes[(i + 1) % kChaseSize];
+    chase_nodes[i].payload = static_cast<char>(folly::Random::rand32(256));
+  }
+  ChaseNode* current_node = &chase_nodes[0];
+  volatile int64_t sink = 0;
+
+  susp.dismiss();
+
+  size_t j = 0;
+  while (iters--) {
+    auto obj =
+        protocol::parseObject<GetReader<apache::thrift::CompactSerializer>>(
+            *buf);
+    folly::doNotOptimizeAway(obj);
+
+    current_node = current_node->next;
+    char payload = current_node->payload;
+    switch ((j++) % 3) {
+      case 0:
+        sink += L1i_switch_0(payload);
+        break;
+      case 1:
+        sink += L1i_switch_1(payload);
+        break;
+      case 2:
+        sink += L1i_switch_2(payload);
+        break;
+    }
+  }
+  folly::doNotOptimizeAway(sink);
+  susp.rehire();
+}
