+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_v11, iters) {
+  folly::BenchmarkSuspender susp;
+  constexpr size_t kSize = 1024 * 16;
+  struct Node {
+    Node* next;
+    char payload;
+  };
+  std::vector<Node> nodes(kSize);
+  for (size_t i = 0; i < kSize; ++i) {
+    nodes[i].next = &nodes[(i + 1) % kSize];
+    nodes[i].payload = (i * 37) & 0xFF;
+  }
+
+  Node* current = &nodes[0];
+  int acc = 0;
+  void (*funcs[])(int, int&) = {switch_func_0, switch_func_1, switch_func_2};
+  susp.dismiss();
+
+  for (size_t i = 0; i < iters; ++i) {
+    current = current->next;
+    funcs[i % 3](current->payload, acc);
+  }
+
+  folly::doNotOptimizeAway(acc);
+  susp.rehire();
+}
