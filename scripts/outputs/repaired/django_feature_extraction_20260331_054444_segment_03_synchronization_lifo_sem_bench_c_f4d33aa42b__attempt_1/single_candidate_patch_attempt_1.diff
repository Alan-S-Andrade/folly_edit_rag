+// New benchmark registration for synchronization_lifo_sem_bench binary
+BENCHMARK_NAMED_PARAM(contendedUse, 8_to_100_plus_frontend_pressure, 8, 100) {
+  // This benchmark is derived from contendedUse(8_to_100).
+  // The modification involves introducing frontend pressure via pointer chasing
+  // and a multi-way switch to induce branch mispredictions and L1I pressure,
+  // while keeping the core post/wait logic similar.
+  // This is intended to increase branch misses and L1-icache-load-misses_MPKI
+  // without significantly impacting IPC or other lower-tier counters.
+
+  LifoSemImpl<std::atomic> sem;
+
+  std::vector<std::thread> threads;
+  std::atomic<bool> go(false);
+
+  BENCHMARK_SUSPEND {
+    for (int t = 0; t < waiters; ++t) {
+      threads.emplace_back([=, &sem] {
+        for (uint32_t i = t; i < n; i += waiters) {
+          sem.wait();
+        }
+      });
+    }
+    for (int t = 0; t < posters; ++t) {
+      threads.emplace_back([=, &sem, &go] {
+        ChainNode* hotPos = &hotNodes[t % kHotLen];
+        uint64_t acc = t;
+
+        while (!go.load()) {
+          std::this_thread::yield();
+        }
+        for (uint32_t i = t; i < n; i += posters) {
+          hotPos = hotPos->next;
+          uint64_t payload = (uint64_t)(uintptr_t)hotPos;
+          switch (i % 3) {
+            case 0:
+              acc = switchA(acc, payload & 0xFF);
+              break;
+            case 1:
+              acc = switchB(acc, payload & 0xFF);
+              break;
+            case 2:
+              acc = switchC(acc, payload & 0xFF);
+              break;
+          }
+          sem.post();
+        }
+        folly::doNotOptimizeAway(acc);
+        folly::doNotOptimizeAway(hotPos);
+      });
+    }
+  }
+
+  go.store(true);
+  for (auto& thr : threads) {
+    thr.join();
+  }
+}
+
 
 BENCHMARK_DRAW_LINE();
 BENCHMARK_NAMED_PARAM(contendedUse, 1_to_1, 1, 1)
