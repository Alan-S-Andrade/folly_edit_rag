+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_v7, iters) {
+    folly::BenchmarkSuspender susp;
+
+    constexpr size_t kDataSize = 4096;
+    std::vector<int> data(kDataSize);
+    // Fill with pseudo-random permutation for pointer chasing
+    for (size_t i = 0; i < kDataSize; ++i) {
+        data[i] = (i * 16381 + 1) % kDataSize; // A simple LCG-like permutation
+    }
+
+    int acc = 0;
+    int current_idx = 0;
+    const int inner_loop_count = 1000;
+
+    susp.dismiss();
+
+    for (size_t i = 0; i < iters; ++i) {
+        for (int j = 0; j < inner_loop_count; ++j) {
+            current_idx = data[current_idx];
+            int selector = current_idx & 0xFF;
+            switch (j % 3) {
+                case 0:
+                    acc = thrash_icache_1(selector, acc);
+                    break;
+                case 1:
+                    acc = thrash_icache_2(selector, acc);
+                    break;
+                case 2:
+                    acc = thrash_icache_3(selector, acc);
+                    break;
+            }
+        }
+    }
+
+    susp.rehire();
+    folly::doNotOptimizeAway(acc);
+}
