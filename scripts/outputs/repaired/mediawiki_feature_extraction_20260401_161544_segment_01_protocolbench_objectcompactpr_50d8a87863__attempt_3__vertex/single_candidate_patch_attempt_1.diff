+
+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_v1, iters) {
+  folly::BenchmarkSuspender susp;
+
+  using Serializer = CompactSerializer;
+  using Struct = LargeSetInt;
+  auto strct = create<Struct>();
+  folly::IOBufQueue q;
+  Serializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+  const uint8_t* data = buf->data();
+  size_t data_size = buf->length();
+
+  const size_t num_nodes = 65536;
+  std::vector<Node_v1> nodes(num_nodes);
+  std::vector<size_t> indices(num_nodes);
+  std::iota(indices.begin(), indices.end(), 0);
+  folly::Random::shuffle(indices);
+
+  for (size_t i = 0; i < num_nodes; ++i) {
+    nodes[indices[i]].next = &nodes[indices[(i + 1) % num_nodes]];
+    nodes[indices[i]].payload = data[indices[i] % data_size];
+  }
+
+  Node_v1* current_node = &nodes[indices[0]];
+  void (*funcs[])(uint8_t) = {func_A_v1, func_B_v1, func_C_v1};
+  int func_idx = 0;
+
+  susp.dismiss();
+
+  while (iters--) {
+    uint8_t val = current_node->payload;
+    funcs[func_idx](val);
+    func_idx = (func_idx + 1) % 3;
+    current_node = current_node->next;
+  }
+
+  susp.rehire();
+  folly::doNotOptimizeAway(current_node);
+  folly::doNotOptimizeAway(global_accumulator_v1);
+}
