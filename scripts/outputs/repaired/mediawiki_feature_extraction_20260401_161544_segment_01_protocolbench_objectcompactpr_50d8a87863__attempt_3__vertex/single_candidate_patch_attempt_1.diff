+volatile int64_t global_accumulator_v1 = 0;
+
+#define ALU_OPS_V1(acc, i, k)                                                  \
+  acc += (i * 3 + k);                                                          \
+  acc ^= (i * 5 + k);                                                          \
+  acc *= (i * 7 + k);                                                          \
+  acc += (i * 11 + k);                                                         \
+  acc ^= (i * 13 + k);                                                         \
+  acc *= (i * 17 + k);                                                         \
+  acc += (i * 19 + k);                                                         \
+  acc ^= (i * 23 + k);                                                         \
+  acc *= (i * 29 + k);                                                         \
+  acc += (i * 31 + k);                                                         \
+  acc ^= (i * 37 + k);                                                         \
+  acc *= (i * 41 + k);                                                         \
+  acc += (i * 43 + k);                                                         \
+  acc ^= (i * 47 + k);                                                         \
+  acc *= (i * 53 + k);                                                         \
+  acc += (i * 59 + k);                                                         \
+  acc ^= (i * 61 + k);                                                         \
+  acc *= (i * 67 + k);                                                         \
+  acc += (i * 71 + k);                                                         \
+  acc ^= (i * 73 + k);                                                         \
+  acc *= (i * 79 + k);                                                         \
+  acc += (i * 83 + k);                                                         \
+  acc ^= (i * 89 + k);                                                         \
+  acc *= (i * 97 + k);                                                         \
+  acc += (i * 101 + k);                                                        \
+  acc ^= (i * 103 + k);                                                        \
+  acc *= (i * 107 + k);                                                        \
+  acc += (i * 109 + k);
+
+#define CASE_BLOCK_V1(i, k) \
+  case i: {                 \
+    ALU_OPS_V1(acc, i, k);  \
+    break;                  \
+  }
+
+#define EIGHT_CASES_V1(i, k) \
+  CASE_BLOCK_V1(i + 0, k)    \
+  CASE_BLOCK_V1(i + 1, k)    \
+  CASE_BLOCK_V1(i + 2, k)    \
+  CASE_BLOCK_V1(i + 3, k)    \
+  CASE_BLOCK_V1(i + 4, k)    \
+  CASE_BLOCK_V1(i + 5, k)    \
+  CASE_BLOCK_V1(i + 6, k)    \
+  CASE_BLOCK_V1(i + 7, k)
+
+#define THIRTY_TWO_CASES_V1(i, k) \
+  EIGHT_CASES_V1(i + 0, k)        \
+  EIGHT_CASES_V1(i + 8, k)        \
+  EIGHT_CASES_V1(i + 16, k)       \
+  EIGHT_CASES_V1(i + 24, k)
+
+#define SWITCH_FUNC_V1(func_name, K_VAL)   \
+  NOINLINE_V1 void func_name(uint8_t val) { \
+    int64_t acc = 0;                       \
+    switch (val) {                         \
+      THIRTY_TWO_CASES_V1(0, K_VAL)        \
+      THIRTY_TWO_CASES_V1(32, K_VAL)       \
+      THIRTY_TWO_CASES_V1(64, K_VAL)       \
+      THIRTY_TWO_CASES_V1(96, K_VAL)       \
+      THIRTY_TWO_CASES_V1(128, K_VAL)      \
+      THIRTY_TWO_CASES_V1(160, K_VAL)      \
+      THIRTY_TWO_CASES_V1(192, K_VAL)      \
+      THIRTY_TWO_CASES_V1(224, K_VAL)      \
+      default:                             \
+        break;                             \
+    }                                      \
+    global_accumulator_v1 += acc;          \
+  }
+
+SWITCH_FUNC_V1(func_A_v1, 1001)
+SWITCH_FUNC_V1(func_B_v1, 2002)
+SWITCH_FUNC_V1(func_C_v1, 3003)
+
+#undef ALU_OPS_V1
