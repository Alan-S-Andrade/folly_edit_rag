+struct ChaseUtil {
+  struct ChainNode {
+    ChainNode* next;
+    char pad[56];
+  };
+  static_assert(sizeof(ChainNode) == 64, "ChainNode should be 64 bytes");
+
+  static constexpr size_t kHotLen = 16384;
+  static constexpr size_t kColdLen = 2u << 20;
+
+  static ChainNode hotNodes[kHotLen];
+  static ChainNode* coldNodes;
+  static std::once_flag init_flag;
+
+  static void init() {
+    std::call_once(init_flag, [] {
+      coldNodes = new ChainNode[kColdLen];
+      initChain(hotNodes, kHotLen);
+      initChain(coldNodes, kColdLen);
+    });
+  }
+
+  static void initChain(ChainNode* nodes, size_t len) {
+    std::vector<size_t> perm(len);
+    std::iota(perm.begin(), perm.end(), 0u);
+    std::mt19937_64 rng(42);
+    for (size_t i = len - 1; i > 0; --i) {
+      std::swap(perm[i], perm[rng() % (i + 1)]);
+    }
+    for (size_t i = 0; i < len; ++i) {
+      nodes[perm[i]].next = &nodes[perm[(i + 1) % len]];
+    }
+  }
+};
+ChaseUtil::ChainNode ChaseUtil::hotNodes[ChaseUtil::kHotLen];
+ChaseUtil::ChainNode* ChaseUtil::coldNodes = nullptr;
+std::once_flag ChaseUtil::init_flag;
+} // namespace
+
+static void contendedUse_v1(uint32_t n, int posters, int waiters) {
+  LifoSemImpl<std::atomic> sem;
+
+  std::vector<std::thread> threads;
+  std::atomic<bool> go(false);
+
+  BENCHMARK_SUSPEND {
+    ChaseUtil::init();
+    for (int t = 0; t < waiters; ++t) {
+      threads.emplace_back([=, &sem] {
+        for (uint32_t i = t; i < n; i += waiters) {
+          sem.wait();
+        }
+      });
+    }
+    for (int t = 0; t < posters; ++t) {
+      threads.emplace_back([=, &sem, &go] {
+        ChaseUtil::ChainNode* hotPos =
+            &ChaseUtil::hotNodes[t % ChaseUtil::kHotLen];
+        ChaseUtil::ChainNode* coldPos =
+            &ChaseUtil::coldNodes[t % ChaseUtil::kColdLen];
+        uint64_t acc = 0;
+
+        while (!go.load()) {
+          std::this_thread::yield();
+        }
+        for (uint32_t i = t; i < n; i += posters) {
+          constexpr size_t INNER_ITERS = 8;
+          for (size_t j = 0; j < INNER_ITERS; ++j) {
+            hotPos = hotPos->next;
+            uint64_t payload = (uint64_t)(uintptr_t)hotPos;
+            switch (j % 3) {
+              case 0:
+                acc = switchA(acc, payload & 0xFF);
+                break;
+              case 1:
+                acc = switchB(acc, payload & 0xFF);
+                break;
+              case 2:
+                acc = switchC(acc, payload & 0xFF);
+                break;
+            }
+            auto coldMask = -uint64_t(j % 8 == 0);
+            coldPos = (ChaseUtil::ChainNode*)((uintptr_t)coldPos->next &
+                                                  coldMask |
+                                              (uintptr_t)coldPos & ~coldMask);
+          }
+          sem.post();
+        }
+        folly::doNotOptimizeAway(acc);
+      });
+    }
+  }
+
+  go.store(true);
+  for (auto& thr : threads) {
+    thr.join();
+  }
+}
