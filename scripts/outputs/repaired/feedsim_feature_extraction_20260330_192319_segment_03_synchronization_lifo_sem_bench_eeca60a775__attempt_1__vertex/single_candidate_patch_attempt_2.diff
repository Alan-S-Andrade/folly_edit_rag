+#define OP1A(c) v += (c)*0x10101
+#define OP2A(c) v ^= (c) << 8
+#define OP3A(c) v = (v << 1) | (v >> 63)
+
+#define OP1B(c) v ^= (c)*0x10101
+#define OP2B(c) v += (c) << 5
+#define OP3B(c) v = (v << 2) | (v >> 62)
+
+#define OP1C(c) v -= (c)*0x101
+#define OP2C(c) v *= (c) | 1
+#define OP3C(c) v = (v << 3) | (v >> 61)
+
+#define CASE(i, op1, op2, op3) \
+  case i:                     \
+    op1(i);                   \
+    op2(i);                   \
+    op3(i);                   \
+    break;
+#define CASES_16(b, op1, op2, op3)                                           \
+  CASE(b + 0, op1, op2, op3) CASE(b + 1, op1, op2, op3) CASE(b + 2, op1, op2, \
+      op3) CASE(b + 3, op1, op2, op3) CASE(b + 4, op1, op2, op3) CASE(        \
+      b + 5, op1, op2, op3) CASE(b + 6, op1, op2, op3) CASE(b + 7, op1, op2,  \
+      op3) CASE(b + 8, op1, op2, op3) CASE(b + 9, op1, op2, op3) CASE(        \
+      b + 10, op1, op2, op3) CASE(b + 11, op1, op2, op3) CASE(b + 12, op1,    \
+      op2, op3) CASE(b + 13, op1, op2, op3) CASE(b + 14, op1, op2,            \
+      op3) CASE(b + 15, op1, op2, op3)
+#define CASES_256(op1, op2, op3)       \
+  CASES_16(0, op1, op2, op3)           \
+  CASES_16(16, op1, op2, op3)          \
+  CASES_16(32, op1, op2, op3)          \
+  CASES_16(48, op1, op2, op3)          \
+  CASES_16(64, op1, op2, op3)          \
+  CASES_16(80, op1, op2, op3)          \
+  CASES_16(96, op1, op2, op3)          \
+  CASES_16(112, op1, op2, op3)         \
+  CASES_16(128, op1, op2, op3)         \
+  CASES_16(144, op1, op2, op3)         \
+  CASES_16(160, op1, op2, op3)         \
+  CASES_16(176, op1, op2, op3)         \
+  CASES_16(192, op1, op2, op3)         \
+  CASES_16(208, op1, op2, op3)         \
+  CASES_16(224, op1, op2, op3)         \
+  CASES_16(240, op1, op2, op3)
+
+__attribute__((noinline)) uint64_t switchA(uint64_t v, int c) {
+  switch (c) {
+    CASES_256(OP1A, OP2A, OP3A);
+  }
+  return v;
+}
+__attribute__((noinline)) uint64_t switchB(uint64_t v, int c) {
+  switch (c) {
+    CASES_256(OP1B, OP2B, OP3B);
+  }
+  return v;
+}
+__attribute__((noinline)) uint64_t switchC(uint64_t v, int c) {
+  switch (c) {
+    CASES_256(OP1C, OP2C, OP3C);
+  }
+  return v;
+}
