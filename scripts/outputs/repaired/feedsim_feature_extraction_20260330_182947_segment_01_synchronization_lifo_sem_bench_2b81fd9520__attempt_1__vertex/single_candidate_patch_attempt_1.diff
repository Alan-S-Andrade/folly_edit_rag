+namespace {
+struct ChainNode {
+  ChainNode* next;
+  char pad[56]; // 64-byte total size
+};
+
+static constexpr size_t kHotLen = 16384; // 1MB
+static constexpr size_t kColdLen = 1u << 20; // 2M nodes, 128MB
+
+static std::unique_ptr<ChainNode[]> hotNodes_ptr;
+static std::unique_ptr<ChainNode[]> coldNodes_ptr;
+static std::once_flag chains_flag;
+
+static void initChain(ChainNode* nodes, size_t len) {
+  std::vector<size_t> perm(len);
+  std::iota(perm.begin(), perm.end(), 0u);
+  std::mt19937_64 rng(42);
+  for (size_t i = len - 1; i > 0; --i) {
+    std::swap(perm[i], perm[rng() % (i + 1)]);
+  }
+  for (size_t i = 0; i < len; ++i) {
+    nodes[perm[i]].next = &nodes[perm[(i + 1) % len]];
+  }
+}
+
+static void initialize_chains() {
+  std::call_once(chains_flag, [] {
+    hotNodes_ptr = std::make_unique<ChainNode[]>(kHotLen);
+    coldNodes_ptr = std::make_unique<ChainNode[]>(kColdLen);
+    initChain(hotNodes_ptr.get(), kHotLen);
+    initChain(coldNodes_ptr.get(), kColdLen);
+  });
+}
+
+#define CASES_16(p, op) \
+  case p + 0: \
+    op; \
+    break; \
+  case p + 1: \
+    op; \
+    break; \
+  case p + 2: \
+    op; \
+    break; \
+  case p + 3: \
+    op; \
+    break; \
+  case p + 4: \
+    op; \
+    break; \
+  case p + 5: \
+    op; \
+    break; \
+  case p + 6: \
+    op; \
+    break; \
+  case p + 7: \
+    op; \
+    break; \
+  case p + 8: \
+    op; \
+    break; \
+  case p + 9: \
+    op; \
+    break; \
+  case p + 10: \
+    op; \
+    break; \
+  case p + 11: \
+    op; \
+    break; \
+  case p + 12: \
+    op; \
+    break; \
+  case p + 13: \
+    op; \
+    break; \
+  case p + 14: \
+    op; \
+    break; \
+  case p + 15: \
+    op; \
+    break;
+
+#define ALL_CASES(op) \
+  CASES_16(0, op) \
+  CASES_16(16, op) \
+  CASES_16(32, op) \
+  CASES_16(48, op) \
+  CASES_16(64, op) \
+  CASES_16(80, op) \
+  CASES_16(96, op) \
+  CASES_16(112, op) \
+  CASES_16(128, op) \
+  CASES_16(144, op) \
+  CASES_16(160, op) \
+  CASES_16(176, op) \
+  CASES_16(192, op) \
+  CASES_16(208, op) \
+  CASES_16(224, op) \
+  CASES_16(240, op)
+
+__attribute__((noinline)) uint64_t switchA(uint64_t v, int c) {
+  switch (c & 0xff) {
+    ALL_CASES(
+        v += (0x1234567890ABCDEF##ULL ^ c);
+        v ^= (0xFEDCBA0987654321##ULL & c))
+  }
+  return v;
+}
+
+__attribute__((noinline)) uint64_t switchB(uint64_t v, int c) {
+  switch (c & 0xff) {
+    ALL_CASES(v = (v << 3) | (v >> 61); v += 0x9876543210FEDCBA##ULL ^ c)
+  }
+  return v;
+}
+
+__attribute__((noinline)) uint64_t switchC(uint64_t v, int c) {
+  switch (c & 0xff) {
+    ALL_CASES(v = ~v; v ^= 0xABCDEF0123456789##ULL | c;
+              v *= 0x1122334455667788##ULL)
+  }
+  return v;
+}
+
+#undef ALL_CASES
+#undef CASES_16
+
+static void contendedUse_v1(uint32_t n, int posters, int waiters) {
+  LifoSemImpl<std::atomic> sem;
+
+  std::vector<std::thread> threads;
+  std::atomic<bool> go(false);
+
+  BENCHMARK_SUSPEND {
+    initialize_chains();
+    auto* hotNodes = hotNodes_ptr.get();
+    auto* coldNodes = coldNodes_ptr.get();
+
+    for (int t = 0; t < waiters; ++t) {
+      threads.emplace_back([=, &sem] {
+        for (uint32_t i = t; i < n; i += waiters) {
+          sem.wait();
+        }
+      });
+    }
+    for (int t = 0; t < posters; ++t) {
+      threads.emplace_back([=, &sem, &go] {
+        ChainNode* hotPos = &hotNodes[(t * 128) % kHotLen];
+        ChainNode* coldPos = &coldNodes[(t * 128) % kColdLen];
+        uint64_t acc = 0;
+
+        while (!go.load()) {
+          std::this_thread::yield();
+        }
+
+        for (uint32_t i = t; i < n; i += posters) {
+          hotPos = hotPos->next;
+          uint64_t payload = (uint64_t)(uintptr_t)hotPos;
+          switch (i % 3) {
+            case 0:
+              acc = switchA(acc, payload);
+              break;
+            case 1:
+              acc = switchB(acc, payload);
+              break;
+            case 2:
+              acc = switchC(acc, payload);
+              break;
+          }
+          auto coldMask = -uint64_t((i & 7) == 0);
+          coldPos = (ChainNode*)(((uintptr_t)coldPos->next & coldMask) |
+                                ((uintptr_t)coldPos & ~coldMask));
+          sem.post();
+        }
+        folly::doNotOptimizeAway(acc);
+      });
+    }
+  }
+
+  go.store(true);
+  for (auto& thr : threads) {
+    thr.join();
+  }
+}
+} // namespace
