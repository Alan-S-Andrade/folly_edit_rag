+#define ALU_CHUNK_IMPL(acc, c1, c2, c3) \
+  acc += c1;                            \
+  acc ^= c2;                            \
+  acc *= c3;
+#define ALU_CHUNK(acc, c) ALU_CHUNK_IMPL(acc, c, c + 1, c + 2)
+
+#define CHURN_CASE(acc, i, c_base)      \
+  case i:                               \
+    ALU_CHUNK(acc, c_base + 0 * 3);     \
+    ALU_CHUNK(acc, c_base + 1 * 3);     \
+    ALU_CHUNK(acc, c_base + 2 * 3);     \
+    ALU_CHUNK(acc, c_base + 3 * 3);     \
+    ALU_CHUNK(acc, c_base + 4 * 3);     \
+    ALU_CHUNK(acc, c_base + 5 * 3);     \
+    ALU_CHUNK(acc, c_base + 6 * 3);     \
+    ALU_CHUNK(acc, c_base + 7 * 3);     \
+    ALU_CHUNK(acc, c_base + 8 * 3);     \
+    acc -= (c_base + 27);               \
+    break;
+
+#define CHURN_CASES_IMPL(acc, base_case, const_base) \
+  CHURN_CASE(acc, base_case + 0, const_base + 0 * 28) \
+  CHURN_CASE(acc, base_case + 1, const_base + 1 * 28) \
+  CHURN_CASE(acc, base_case + 2, const_base + 2 * 28) \
+  CHURN_CASE(acc, base_case + 3, const_base + 3 * 28) \
+  CHURN_CASE(acc, base_case + 4, const_base + 4 * 28) \
+  CHURN_CASE(acc, base_case + 5, const_base + 5 * 28) \
+  CHURN_CASE(acc, base_case + 6, const_base + 6 * 28) \
+  CHURN_CASE(acc, base_case + 7, const_base + 7 * 28)
+
+#define CHURN_CASES_16(acc, base_case, const_base) \
+  CHURN_CASES_IMPL(acc, base_case + 0, const_base + 0 * 28 * 8) \
+  CHURN_CASES_IMPL(acc, base_case + 8, const_base + 1 * 28 * 8)
+
+#define CHURN_CASES_256(acc, const_base) \
+  CHURN_CASES_16(acc,   0, const_base + ( 0 * 28 * 16)) \
+  CHURN_CASES_16(acc,  16, const_base + ( 1 * 28 * 16)) \
+  CHURN_CASES_16(acc,  32, const_base + ( 2 * 28 * 16)) \
+  CHURN_CASES_16(acc,  48, const_base + ( 3 * 28 * 16)) \
+  CHURN_CASES_16(acc,  64, const_base + ( 4 * 28 * 16)) \
+  CHURN_CASES_16(acc,  80, const_base + ( 5 * 28 * 16)) \
+  CHURN_CASES_16(acc,  96, const_base + ( 6 * 28 * 16)) \
+  CHURN_CASES_16(acc, 112, const_base + ( 7 * 28 * 16)) \
+  CHURN_CASES_16(acc, 128, const_base + ( 8 * 28 * 16)) \
+  CHURN_CASES_16(acc, 144, const_base + ( 9 * 28 * 16)) \
+  CHURN_CASES_16(acc, 160, const_base + (10 * 28 * 16)) \
+  CHURN_CASES_16(acc, 176, const_base + (11 * 28 * 16)) \
+  CHURN_CASES_16(acc, 192, const_base + (12 * 28 * 16)) \
+  CHURN_CASES_16(acc, 208, const_base + (13 * 28 * 16)) \
+  CHURN_CASES_16(acc, 224, const_base + (14 * 28 * 16)) \
+  CHURN_CASES_16(acc, 240, const_base + (15 * 28 * 16))
+
+__attribute__((noinline))
+int churn_code_1(int acc_in, int val) {
+    volatile int acc = acc_in;
+    switch (val & 0xFF) {
+      CHURN_CASES_256(acc, 1)
+      default: __builtin_unreachable();
+    }
+    return acc;
+}
+
+__attribute__((noinline))
+int churn_code_2(int acc_in, int val) {
+    volatile int acc = acc_in;
+    switch (val & 0xFF) {
+      CHURN_CASES_256(acc, 1 + 256 * 28)
+      default: __builtin_unreachable();
+    }
+    return acc;
+}
+
+__attribute__((noinline))
+int churn_code_3(int acc_in, int val) {
+    volatile int acc = acc_in;
+    switch (val & 0xFF) {
+      CHURN_CASES_256(acc, 1 + 2 * 256 * 28)
+      default: __builtin_unreachable();
+    }
+    return acc;
+}
+
+void readBench_LargeSetInt_v2(size_t iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<LargeSetInt>();
+  folly::IOBufQueue q;
+  CompactSerializer::serialize(strct, &q);
+  auto buf = q.move();
+  // coalesce the IOBuf chain to test fast path
+  buf->coalesce();
+  susp.dismiss();
+
+  while (iters--) {
+    auto obj = protocol::parseObject<GetReader<CompactSerializer>>(*buf);
+    folly::doNotOptimizeAway(obj);
+
+    const auto data = obj.as<LargeSetInt>();
+    const auto& s = *data.field_ref();
+    int acc = 0;
+    int j = 0;
+    for (const auto& val : s) {
+      int switch_val = val;
+      switch ((j++) % 3) {
+        case 0:
+          acc = churn_code_1(acc, switch_val);
+          break;
+        case 1:
+          acc = churn_code_2(acc, switch_val);
+          break;
+        case 2:
+          acc = churn_code_3(acc, switch_val);
+          break;
+      }
+    }
+    folly::doNotOptimizeAway(acc);
+  }
+  susp.rehire();
+}
+}
+
+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_v2, iters) {
+    readBench_LargeSetInt_v2(iters);
+}
