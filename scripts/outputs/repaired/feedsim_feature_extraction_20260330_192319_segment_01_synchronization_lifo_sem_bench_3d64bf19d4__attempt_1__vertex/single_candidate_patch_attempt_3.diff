+#define CASE_BLOCK(i, salt)              \
+  case i:                                \
+    v += salt;                           \
+    v ^= (v >> 17);                      \
+    v *= 0x123456789abcdef1ULL;          \
+    v ^= (v >> 23);                      \
+    break;
+
+#define CASES_16(i, salt)                                                   \
+  CASE_BLOCK(i + 0, salt) CASE_BLOCK(i + 1, salt) CASE_BLOCK(i + 2, salt)   \
+      CASE_BLOCK(i + 3, salt) CASE_BLOCK(i + 4, salt) CASE_BLOCK(i + 5, salt) \
+      CASE_BLOCK(i + 6, salt) CASE_BLOCK(i + 7, salt) CASE_BLOCK(i + 8, salt) \
+      CASE_BLOCK(i + 9, salt) CASE_BLOCK(i + 10, salt)                        \
+      CASE_BLOCK(i + 11, salt) CASE_BLOCK(i + 12, salt)                       \
+      CASE_BLOCK(i + 13, salt) CASE_BLOCK(i + 14, salt)                       \
+      CASE_BLOCK(i + 15, salt)
+
+#define CASES_256(i, salt)                                                    \
+  CASES_16(i + 0, salt) CASES_16(i + 16, salt) CASES_16(i + 32, salt)          \
+      CASES_16(i + 48, salt) CASES_16(i + 64, salt) CASES_16(i + 80, salt)      \
+      CASES_16(i + 96, salt) CASES_16(i + 112, salt) CASES_16(i + 128, salt)    \
+      CASES_16(i + 144, salt) CASES_16(i + 160, salt) CASES_16(i + 176, salt)  \
+      CASES_16(i + 192, salt) CASES_16(i + 208, salt) CASES_16(i + 224, salt)  \
+      CASES_16(i + 240, salt)
+
+__attribute__((noinline)) uint64_t switchA(uint64_t v, int c) {
+  switch (c & 0xff) {
+    CASES_256(0, 0x1111111111111111ULL)
+  }
+  return v;
+}
+__attribute__((noinline)) uint64_t switchB(uint64_t v, int c) {
+  switch (c & 0xff) {
+    CASES_256(0, 0x2222222222222222ULL)
+  }
+  return v;
+}
+__attribute__((noinline)) uint64_t switchC(uint64_t v, int c) {
+  switch (c & 0xff) {
+    CASES_256(0, 0x3333333333333333ULL)
+  }
+  return v;
+}
+
+struct ChainNode {
+  ChainNode* next;
+  char pad[56]; // 64 bytes total
+};
+
+static void initChain(ChainNode* nodes, size_t len) {
+  std::vector<size_t> perm(len);
+  std::iota(perm.begin(), perm.end(), 0u);
+  std::mt19937_64 rng(42);
+  for (size_t i = len - 1; i > 0; --i) {
+    std::swap(perm[i], perm[rng() % (i + 1)]);
+  }
+  for (size_t i = 0; i < len; ++i) {
+    nodes[perm[i]].next = &nodes[perm[(i + 1) % len]];
+  }
+}
+
+struct WorkloadData {
+  static constexpr size_t kHotLen = 16384; // 1MB
+  static constexpr size_t kColdLen = 2 * 1024 * 1024; // 128MB
+
+  std::vector<ChainNode> hotNodes;
+  std::unique_ptr<ChainNode[]> coldNodes;
+
+  WorkloadData() : hotNodes(kHotLen) {
+    coldNodes.reset(new ChainNode[kColdLen]);
+    initChain(hotNodes.data(), kHotLen);
+    initChain(coldNodes.get(), kColdLen);
+  }
+};
+
+std::unique_ptr<WorkloadData> workloadData;
+std::once_flag initFlag;
+
+void initialize_workload() {
+  std::call_once(initFlag, [] {
+    workloadData = std::make_unique<WorkloadData>();
+  });
+}
