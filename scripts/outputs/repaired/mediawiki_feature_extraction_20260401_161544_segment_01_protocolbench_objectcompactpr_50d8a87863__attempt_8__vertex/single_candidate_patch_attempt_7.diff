+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_ipc_v1, iters) {
+  folly::BenchmarkSuspender susp;
+
+  struct Node {
+    Node* next;
+    uint32_t payload;
+  };
+  constexpr size_t kNumNodes = 4096;
+  static std::vector<Node> nodes(kNumNodes);
+
+  if (nodes[0].next == nullptr) { // one-time initialization
+    std::vector<size_t> indices(kNumNodes);
+    std::iota(indices.begin(), indices.end(), 0);
+    std::shuffle(indices.begin(), indices.end(), folly::ThreadLocalPRNG());
+
+    for (size_t i = 0; i < kNumNodes; ++i) {
+      nodes[indices[i]].next = &nodes[indices[(i + 1) % kNumNodes]];
+      nodes[i].payload = folly::Random::rand32();
+    }
+  }
+
+  Node* p = &nodes[0];
+  int64_t dep = 0;
+
+  susp.dismiss();
+
+  for (size_t i = 0; i < iters; ++i) {
+    uint8_t idx = p->payload & 0xFF;
+    switch (i % 3) {
+      case 0:
+        dep = worker_func_0(dep, idx);
+        break;
+      case 1:
+        dep = worker_func_1(dep, idx);
+        break;
+      case 2:
+        dep = worker_func_2(dep, idx);
+        break;
+    }
+    p = p->next;
+  }
+
+  folly::doNotOptimizeAway(dep);
+  folly::doNotOptimizeAway(p);
+}
 
