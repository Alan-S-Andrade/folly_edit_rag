+static void contendedUse_derived_1(uint32_t n, int posters, int waiters) {
+  LifoSemImpl<std::atomic> sem;
+
+  std::vector<std::thread> threads;
+  std::atomic<bool> go(false);
+
+  BENCHMARK_SUSPEND {
+    for (int t = 0; t < waiters; ++t) {
+      threads.emplace_back([=, &sem] {
+        for (uint32_t i = t; i < n; i += waiters) {
+          sem.wait();
+        }
+      });
+    }
+    for (int t = 0; t < posters; ++t) {
+      threads.emplace_back([=, &sem, &go] {
+        uint64_t acc = t; // Initialize an accumulator for some work
+
+        while (!go.load()) {
+          std::this_thread::yield();
+        }
+        for (uint32_t i = t; i < n; i += posters) {
+          // Minimal work to try and improve IPC in poster threads
+          acc = acc * 13 + (i % 7); // Simple arithmetic to add some instructions
+          folly::doNotOptimizeAway(acc);
+
+          sem.post();
+        }
+        folly::doNotOptimizeAway(acc); // Ensure acc isn't optimized away entirely
+      });
+    }
+  }
+
+  go.store(true);
+  for (auto& thr : threads) {
+    thr.join();
+  }
+}
 } // namespace
 
