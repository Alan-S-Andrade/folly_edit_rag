 OpEncodeX(OpEncode, Binary)
 OpEncodeX(OpEncode, Compact)
 
+// Derived benchmark: stress i-cache by interleaving parse with a volatile
+// indirect call to force re-fetching instruction cache lines each iteration.
+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_icache, iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<LargeSetInt>();
+  folly::IOBufQueue q;
+  CompactSerializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+  // Build many independent serialized copies to prevent the CPU from
+  // keeping the same hot cache lines warm across iterations.
+  constexpr size_t kNumBufs = 64;
+  std::vector<std::unique_ptr<folly::IOBuf>> bufs;
+  bufs.reserve(kNumBufs);
+  for (size_t i = 0; i < kNumBufs; ++i) {
+    bufs.push_back(buf->clone());
+  }
+  susp.dismiss();
+
+  size_t idx = 0;
+  while (iters--) {
+    auto obj = protocol::parseObject<CompactProtocolReader>(*bufs[idx]);
+    folly::doNotOptimizeAway(obj);
+    idx = (idx + 1) & (kNumBufs - 1);
+  }
+  susp.rehire();
+}
+
 int main(int argc, char** argv) {
   folly::Init init(&argc, &argv);
   folly::runBenchmarks();
