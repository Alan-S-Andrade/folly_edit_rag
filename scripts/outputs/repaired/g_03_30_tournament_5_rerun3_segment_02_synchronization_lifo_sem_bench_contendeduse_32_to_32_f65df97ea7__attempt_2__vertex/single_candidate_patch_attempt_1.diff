+// Returns a pointer to the start of a dependency chain.
+FOLLY_NOINLINE ChaseNode* getChaseHead() {
+  static std::vector<ChaseNode> nodes = [] {
+    constexpr size_t kSize = 1 << 16;
+    std::vector<ChaseNode> v(kSize);
+    std::vector<size_t> indices(kSize);
+    std::iota(indices.begin(), indices.end(), 0);
+    std::mt19937 g(1); // deterministic shuffle
+    std::shuffle(indices.begin(), indices.end(), g);
+    for (size_t i = 0; i < kSize; ++i) {
+      v[indices[i]].next = &v[indices[(i + 1) % kSize]];
+      v[indices[i]].payload = i * 37;
+    }
+    return v;
+  }();
+  return &nodes[0];
+}
