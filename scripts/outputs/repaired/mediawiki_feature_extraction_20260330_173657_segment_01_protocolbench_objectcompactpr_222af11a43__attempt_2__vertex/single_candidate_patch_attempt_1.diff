+template <
+    SerializerMethod kSerializerMethod,
+    typename Serializer,
+    typename Struct>
+void readBench_v1(size_t iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<Struct>();
+  folly::IOBufQueue q;
+  Serializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+
+  std::vector<int> values;
+  if constexpr (std::is_same_v<Struct, LargeSetInt>) {
+    if (auto r = strct.field_1_ref()) {
+      values.assign(r->begin(), r->end());
+    }
+  }
+  if (values.empty()) {
+    values.resize(1024);
+    std::iota(values.begin(), values.end(), 0);
+  }
+
+  std::vector<size_t> chase(values.size());
+  for (size_t i = 0; i < values.size(); ++i) {
+    chase[i] = (size_t)std::abs(values[i]) % values.size();
+  }
+
+  susp.dismiss();
+
+  size_t idx = 0;
+  int acc = 0;
+  while (iters--) {
+    if constexpr (kSerializerMethod == SerializerMethod::Object) {
+      auto obj = protocol::parseObject<GetReader<Serializer>>(*buf);
+      folly::doNotOptimizeAway(obj);
+
+      idx = chase[idx];
+      int val = values[idx];
+
+      switch ((iters) % 3) {
+        case 0:
+          acc = alu_work_func_0(acc, val);
+          break;
+        case 1:
+          acc = alu_work_kindof_1(acc, val);
+          break;
+        case 2:
+          acc = alu_work_other_2(acc, val);
+          break;
+      }
+    } else {
+      Struct data;
+      Serializer::deserialize(buf.get(), data);
+      folly::doNotOptimizeAway(data);
+    }
+  }
+  folly::doNotOptimizeAway(acc);
   susp.rehire();
 }
 
