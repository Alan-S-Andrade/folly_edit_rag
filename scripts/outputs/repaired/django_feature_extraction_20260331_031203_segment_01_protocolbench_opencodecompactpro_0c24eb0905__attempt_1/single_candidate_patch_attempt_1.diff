+// This new benchmark variant simplifies the ComplexStruct by clearing its
+// dynamic container fields (map, set, list) before serialization. This should
+// reduce the amount of data written during deserialization, potentially
+// improving IPC and reducing L1-dcache-stores_SPKI.
+BENCHMARK(OpEncodeCompactProtocol_read_ComplexStruct_Simplified, iters) {
+  readBench_SimplifiedComplexStruct<
+      getSerializerMethod("OpEncode"),
+      CompactSerializer,
+      OpComplexStruct>(iters);
+}
