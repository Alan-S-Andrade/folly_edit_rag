+namespace {
+#define OPS_10(V, C1, C2, C3, C4) \
+  V = (V ^ C1) + 2;               \
+  V = (V * C2) - 1;               \
+  V = (V ^ (C3 + V)) * 3;         \
+  V = V + (C4 - V);               \
+  V = (V * C1) ^ 4;               \
+  V = (V + C2) * 5;               \
+  V = (V - C3) ^ V;               \
+  V = (V * C4) + 6;               \
+  V = (V ^ (C1 + 2)) * 7;         \
+  V = V + (C2 - 3);
+
+#define OPS_30(V, C1, C2, C3, C4) \
+  OPS_10(V, C1, C2, C3, C4)       \
+  OPS_10(V, C2, C3, C4, C1)       \
+  OPS_10(V, C3, C4, C1, C2)
+
+__attribute__((noinline)) int stress_func_1(int v, int i) {
+  switch (i) {
+#define CASE(N) \
+  case N:       \
+    OPS_30(v, N + 0x1100, N + 0x2200, N + 0x3300, N + 0x4400); \
+    break;
+#define C4(N) \
+  CASE(N)     \
+  CASE(N + 1) \
+  CASE(N + 2) \
+  CASE(N + 3)
+#define C16(N) \
+  C4(N)        \
+  C4(N + 4)    \
+  C4(N + 8)    \
+  C4(N + 12)
+#define C64(N) \
+  C16(N)       \
+  C16(N + 16)  \
+  C16(N + 32)  \
+  C16(N + 48)
+#define C256(N) \
+  C64(N)        \
+  C64(N + 64)   \
+  C64(N + 128)  \
+  C64(N + 192)
+    C256(0)
+#undef CASE
+#undef C4
+#undef C16
+#undef C64
+#undef C256
+  }
+  return v;
+}
+
