+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_ipc_v1, iters) {
+  folly::BenchmarkSuspender susp;
+  using Serializer = CompactSerializer;
+  using Struct = LargeSetInt;
+  using Reader = GetReader<Serializer>;
+
+  auto strct = create<Struct>();
+  folly::IOBufQueue q;
+  Serializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+
+  static StressState stress_state; // initialized once
+  int chase_idx = 0;
+  int accum = 0;
+  unsigned int j = 0;
+
+  susp.dismiss();
+
+  while (iters--) {
+    auto obj = protocol::parseObject<Reader>(*buf);
+    folly::doNotOptimizeAway(obj);
+
+    chase_idx = stress_state.chase_arr[chase_idx];
+    auto payload_ptr = reinterpret_cast<const uint8_t*>(buf->data());
+    int switch_idx = payload_ptr[chase_idx % buf->length()];
+
+    switch (j++ % 3) {
+      case 0:
+        accum = stress_func_1(accum, switch_idx);
+        break;
+      case 1:
+        accum = stress_func_2(accum, switch_idx);
+        break;
+      default:
+        accum = stress_func_3(accum, switch_idx);
+        break;
+    }
+  }
+
+  folly::doNotOptimizeAway(accum);
+  susp.rehire();
+}
