+struct StressState {
+  std::vector<int> chase_arr;
+  StressState() {
+    constexpr int kChaseSize = 4096;
+    chase_arr.resize(kChaseSize);
+    for (int i = 0; i < kChaseSize; ++i) {
+      chase_arr[i] = i;
+    }
+
+    uint64_t state = 0xdeadbeefcafebabe;
+    for (int i = kChaseSize - 1; i > 0; --i) {
+      state = state * 6364136223846793005ULL + 1442695040888963407ULL;
+      std::swap(chase_arr[i], chase_arr[state % (i + 1)]);
+    }
+  }
+};
