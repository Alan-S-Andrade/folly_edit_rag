+// Variant of readBench for ObjectCompactProtocol_read_LargeSetInt that
+// performs two independent parse passes per iteration, introducing extra
+// frontend pressure (more branches and icache footprint) while keeping the
+// same deserialization character.
+template <typename Serializer, typename Struct>
+void readBenchDualPass(size_t iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<Struct>();
+  folly::IOBufQueue q;
+  Serializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+  susp.dismiss();
+
+  while (iters--) {
+    auto obj0 = protocol::parseObject<GetReader<Serializer>>(*buf);
+    folly::doNotOptimizeAway(obj0);
+    auto obj1 = protocol::parseObject<GetReader<Serializer>>(*buf);
+    folly::doNotOptimizeAway(obj1);
   }
   susp.rehire();
 }
