+// Variant of readBench that performs two deserializations per iteration to
+// increase instruction-level parallelism and raise IPC relative to the
+// single-deserialize baseline.
+template <
+    SerializerMethod kSerializerMethod,
+    typename Serializer,
+    typename Struct>
+void readBenchDouble(size_t iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<Struct>();
+  folly::IOBufQueue q;
+  Serializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+  susp.dismiss();
+
+  while (iters--) {
+    Struct data0;
+    Serializer::deserialize(buf.get(), data0);
+    folly::doNotOptimizeAway(data0);
+    Struct data1;
+    Serializer::deserialize(buf.get(), data1);
+    folly::doNotOptimizeAway(data1);
   }
   susp.rehire();
 }
