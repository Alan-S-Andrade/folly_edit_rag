+struct alignas(64) ChainNode {
+  ChainNode* next;
+  char pad[64 - sizeof(ChainNode*)];
+};
+
+static constexpr size_t kHotLen = 16384; // 1MB
+static ChainNode hotNodes[kHotLen];
+static constexpr size_t kColdLen = 1u << 21; // 2M nodes, 128MB
+static ChainNode* coldNodes = nullptr;
+
+static std::once_flag initChainsFlag;
+
+void initChain(ChainNode* nodes, size_t len) {
+  std::vector<size_t> perm(len);
+  std::iota(perm.begin(), perm.end(), 0u);
+  std::mt19937_64 rng(42);
+  for (size_t i = len - 1; i > 0; --i) {
+    std::swap(perm[i], perm[rng() % (i + 1)]);
+  }
+  for (size_t i = 0; i < len; ++i) {
+    nodes[perm[i]].next = &nodes[perm[(i + 1) % len]];
+  }
+}
+
+void doInitChains() {
+  coldNodes = new ChainNode[kColdLen];
+  initChain(hotNodes, kHotLen);
+  initChain(coldNodes, kColdLen);
+}
+
+#define GEN_SWITCH_CASES(val, v)                                            \
+  case val + 0:                                                             \
+    v += 0x1234567;                                                         \
+    v = (v << 3) | (v >> 61);                                               \
+    break;                                                                  \
+  case val + 1:                                                             \
+    v ^= 0x2345678;                                                         \
+    v = (v << 3) | (v >> 61);                                               \
+    break;                                                                  \
+  case val + 2:                                                             \
+    v += 0x3456789;                                                         \
+    v = (v << 3) | (v >> 61);                                               \
+    break;                                                                  \
+  case val + 3:                                                             \
+    v ^= 0x456789a;                                                         \
+    v = (v << 3) | (v >> 61);                                               \
+    break;                                                                  \
+  case val + 4:                                                             \
+    v += 0x56789ab;                                                         \
+    v = (v << 3) | (v >> 61);                                               \
+    break;                                                                  \
+  case val + 5:                                                             \
+    v ^= 0x6789abc;                                                         \
+    v = (v << 3) | (v >> 61);                                               \
+    break;                                                                  \
+  case val + 6:                                                             \
+    v += 0x789abcd;                                                         \
+    v = (v << 3) | (v >> 61);                                               \
+    break;                                                                  \
+  case val + 7:                                                             \
+    v ^= 0x89abcde;                                                         \
+    v = (v << 3) | (v >> 61);                                               \
+    break;
+
+__attribute__((noinline)) uint64_t switchA(uint64_t v, int c) {
+  switch (c) {
+    GEN_SWITCH_CASES(0, v)
+    GEN_SWITCH_CASES(8, v)
+    GEN_SWITCH_CASES(16, v)
+    GEN_SWITCH_CASES(24, v)
+    default:
+      v += c;
+      break;
+  }
+  return v;
+}
+
+__attribute__((noinline)) uint64_t switchB(uint64_t v, int c) {
+  switch (c) {
+    GEN_SWITCH_CASES(0, v)
+    GEN_SWITCH_CASES(8, v)
+    GEN_SWITCH_CASES(16, v)
+    GEN_SWITCH_CASES(24, v)
+    default:
+      v ^= c;
+      break;
+  }
+  return v;
+}
+
+__attribute__((noinline)) uint64_t switchC(uint64_t v, int c) {
+  switch (c) {
+    GEN_SWITCH_CASES(0, v)
+    GEN_SWITCH_CASES(8, v)
+    GEN_SWITCH_CASES(16, v)
+    GEN_SWITCH_CASES(24, v)
+    default:
+      v -= c;
+      break;
+  }
+  return v;
+}
+
