+  }
+  return v;
+}
+
+struct ChaseBenchUtil {
+  ChaseBenchUtil() {
+    if (!hotNodes) {
+      hotNodes = std::make_unique<ChainNode[]>(kHotLen);
+      initChain(hotNodes.get(), kHotLen);
+    }
+    if (!coldNodes) {
+      coldNodes = std::make_unique<ChainNode[]>(kColdLen);
+      initChain(coldNodes.get(), kColdLen);
+    }
+  }
+};
