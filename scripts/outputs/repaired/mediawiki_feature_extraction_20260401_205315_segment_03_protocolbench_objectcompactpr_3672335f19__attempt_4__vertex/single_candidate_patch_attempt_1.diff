+    break;                                                          \
+  case i + 5:                                                       \
+    OPS_V4(acc, (i + 5) * 28 + func_offset);                        \
+    break;                                                          \
+  case i + 6:                                                       \
+    OPS_V4(acc, (i + 6) * 28 + func_offset);                        \
