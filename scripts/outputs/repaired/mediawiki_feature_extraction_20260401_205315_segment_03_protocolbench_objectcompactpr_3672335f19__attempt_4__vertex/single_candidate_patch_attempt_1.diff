+// I-cache-heavy workload to increase L1-icache-load-misses_MPKI
+#define OPS_V4(acc, c)                                     \
+  acc += c + 1;                                            \
+  acc ^= c + 2;                                            \
+  acc *= c + 3;                                            \
+  acc += c + 4;                                            \
+  acc ^= c + 5;                                            \
+  acc += c + 6;                                            \
+  acc ^= c + 7;                                            \
+  acc *= c + 8;                                            \
