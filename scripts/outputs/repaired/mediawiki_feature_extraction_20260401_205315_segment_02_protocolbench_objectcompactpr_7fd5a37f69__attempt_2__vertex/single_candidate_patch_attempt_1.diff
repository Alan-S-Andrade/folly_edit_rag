+  CASES_1(i + 11)     \
+  CASES_1(i + 12)     \
+  CASES_1(i + 13)     \
+  CASES_1(i + 14)     \
+  CASES_1(i + 15)
+#define CASES_256     \
+  CASES_16(0)         \
+  CASES_16(16)        \
+  CASES_16(32)        \
+  CASES_16(48)        \
+  CASES_16(64)        \
+  CASES_16(80)        \
+  CASES_16(96)        \
