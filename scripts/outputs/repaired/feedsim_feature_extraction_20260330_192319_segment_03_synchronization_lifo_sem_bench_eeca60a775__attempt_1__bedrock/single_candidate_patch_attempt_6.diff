+// contendedUse variant with tryWait spinning before blocking wait,
+// materially changing the hot path relative to plain contendedUse.
+static void contendedUse_tryWaitSpin(uint32_t n, int posters, int waiters) {
+  LifoSemImpl<std::atomic> sem;
+
+  std::vector<std::thread> threads;
+  std::atomic<bool> go(false);
+
+  BENCHMARK_SUSPEND {
+    for (int t = 0; t < waiters; ++t) {
+      threads.emplace_back([=, &sem] {
+        for (uint32_t i = t; i < n; i += waiters) {
+          // Spin with tryWait up to 64 times before falling back to wait()
+          bool got = false;
+          for (int spin = 0; spin < 64; ++spin) {
+            if (sem.tryWait()) {
+              got = true;
+              break;
+            }
+            asm_volatile_memory();
+          }
+          if (!got) {
+            sem.wait();
+          }
+        }
+      });
+    }
+    for (int t = 0; t < posters; ++t) {
+      threads.emplace_back([=, &sem, &go] {
+        while (!go.load()) {
+          std::this_thread::yield();
+        }
+        for (uint32_t i = t; i < n; i += posters) {
+          sem.post();
+        }
+      });
+    }
+  }
+
+  go.store(true);
+  for (auto& thr : threads) {
+    thr.join();
+  }
+}
+
+// contendedUse variant with batched post (post N tokens at once then wait N),
+// materially changing the hot path relative to plain contendedUse.
+static void contendedUse_batchedPost(uint32_t n, int posters, int waiters) {
+  LifoSemImpl<std::atomic> sem;
+
+  std::vector<std::thread> threads;
+  std::atomic<bool> go(false);
+
+  static constexpr int kBatch = 4;
+
+  BENCHMARK_SUSPEND {
+    for (int t = 0; t < waiters; ++t) {
+      threads.emplace_back([=, &sem] {
+        for (uint32_t i = t; i < n; i += waiters) {
+          sem.wait();
+          asm_volatile_memory();
+          asm_volatile_memory();
+        }
+      });
+    }
+    for (int t = 0; t < posters; ++t) {
+      threads.emplace_back([=, &sem, &go] {
+        while (!go.load()) {
+          std::this_thread::yield();
+        }
+        uint32_t i = t;
+        while (i < n) {
+          // Post up to kBatch tokens in a tight loop before yielding
+          int batch = 0;
+          while (batch < kBatch && i < n) {
+            sem.post();
+            i += posters;
+            ++batch;
+          }
+          asm_volatile_memory();
+        }
+      });
+    }
+  }
+
+  go.store(true);
+  for (auto& thr : threads) {
+    thr.join();
+  }
+}
