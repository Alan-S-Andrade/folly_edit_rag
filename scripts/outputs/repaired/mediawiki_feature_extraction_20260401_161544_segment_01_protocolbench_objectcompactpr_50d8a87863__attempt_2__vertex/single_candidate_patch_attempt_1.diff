+#define OPS_1(acc, c) \
+  acc += c;           \
+  acc ^= (c + 1);     \
+  acc *= (c + 2);     \
+  acc -= (c + 3);
+#define OPS_SET(acc, c) \
+  OPS_1(acc, c)         \
+  OPS_1(acc, c + 4)     \
+  OPS_1(acc, c + 8)     \
+  OPS_1(acc, c + 12)    \
+  OPS_1(acc, c + 16)    \
+  OPS_1(acc, c + 20)    \
+  OPS_1(acc, c + 24)
+
+#define CASE(i, acc, C_OFF)          \
+  case i:                            \
+    OPS_SET(acc, (i * 28 + C_OFF)); \
+    break;
+
+#define CASES_16(i, acc, C_OFF) \
+  CASE(i, acc, C_OFF)           \
+  CASE(i + 1, acc, C_OFF)       \
+  CASE(i + 2, acc, C_OFF)       \
+  CASE(i + 3, acc, C_OFF)       \
+  CASE(i + 4, acc, C_OFF)       \
+  CASE(i + 5, acc, C_OFF)       \
+  CASE(i + 6, acc, C_OFF)       \
+  CASE(i + 7, acc, C_OFF)       \
+  CASE(i + 8, acc, C_OFF)       \
+  CASE(i + 9, acc, C_OFF)       \
+  CASE(i + 10, acc, C_OFF)      \
+  CASE(i + 11, acc, C_OFF)      \
+  CASE(i + 12, acc, C_OFF)      \
+  CASE(i + 13, acc, C_OFF)      \
+  CASE(i + 14, acc, C_OFF)      \
+  CASE(i + 15, acc, C_OFF)
+
+#define CASES_256(acc, C_OFF)   \
+  CASES_16(0, acc, C_OFF)       \
+  CASES_16(16, acc, C_OFF)      \
+  CASES_16(32, acc, C_OFF)      \
+  CASES_16(48, acc, C_OFF)      \
+  CASES_16(64, acc, C_OFF)      \
+  CASES_16(80, acc, C_OFF)      \
+  CASES_16(96, acc, C_OFF)      \
+  CASES_16(112, acc, C_OFF)     \
+  CASES_16(128, acc, C_OFF)     \
+  CASES_16(144, acc, C_OFF)     \
+  CASES_16(160, acc, C_OFF)     \
+  CASES_16(176, acc, C_OFF)     \
+  CASES_16(192, acc, C_OFF)     \
+  CASES_16(208, acc, C_OFF)     \
+  CASES_16(224, acc, C_OFF)     \
+  CASES_16(240, acc, C_OFF)
+
+__attribute__((noinline)) int64_t icache_thrash_A(
+    uint8_t selector,
+    int64_t acc) {
+  switch (selector) {
+    CASES_256(acc, 0)
+    default:
+      break;
+  }
+  return acc;
+}
+
+__attribute__((noinline)) int64_t icache_thrash_B(
+    uint8_t selector,
+    int64_t acc) {
+  switch (selector) {
+    CASES_256(acc, 256 * 28)
+    default:
+      break;
+  }
+  return acc;
+}
+
+__attribute__((noinline)) int64_t icache_thrash_C(
+    uint8_t selector,
+    int64_t acc) {
+  switch (selector) {
+    CASES_256(acc, 2 * 256 * 28)
+    default:
+      break;
+  }
+  return acc;
+}
 
