+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_iCacheStall, iters) {
+  folly::BenchmarkSuspender susp;
+  using Serializer = CompactSerializer;
+  using Struct = LargeSetInt;
+  auto strct = create<Struct>();
+  folly::IOBufQueue q;
+  Serializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+
+  struct Node {
+    Node* next;
+    uint8_t payload;
+  };
+  constexpr size_t chase_size = 4096;
+  std::vector<Node> nodes(chase_size);
+  for (size_t i = 0; i < chase_size; ++i) {
+    nodes[i].next = &nodes[(i + 1) % chase_size];
+    nodes[i].payload = i % 256;
+  }
+  Node* p = &nodes[0];
+  int64_t acc = 0;
+
+  susp.dismiss();
+
+  size_t n = iters;
+  while (n--) {
+    auto obj = protocol::parseObject<GetReader<Serializer>>(*buf);
+    folly::doNotOptimizeAway(obj);
+
+    constexpr int thrash_iters = 100;
+    for (int j = 0; j < thrash_iters; ++j) {
+      uint8_t selector = p->payload;
+      p = p->next;
+      switch (j % 3) {
+        case 0:
+          acc = icache_thrash_A(selector, acc);
+          break;
+        case 1:
+          acc = icache_thrash_B(selector, acc);
+          break;
+        case 2:
+          acc = icache_thrash_C(selector, acc);
+          break;
+      }
+    }
+  }
+
+  susp.rehire();
+  folly::doNotOptimizeAway(acc);
+}
+
 int main(int argc, char** argv) {
   folly::Init init(&argc, &argv);
   folly::runBenchmarks();
