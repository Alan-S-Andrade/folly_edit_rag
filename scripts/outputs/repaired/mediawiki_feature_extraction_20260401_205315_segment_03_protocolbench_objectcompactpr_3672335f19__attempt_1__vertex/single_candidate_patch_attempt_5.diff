+namespace {
+FOLLY_NOINLINE int func1_v1(int x) {
+  switch (x % 4) {
+    case 0:
+      return x * 2;
+    case 1:
+      return x + 1;
+    case 2:
+      return x >> 1;
+    case 3:
+      return x - 1;
+  }
+  return x;
+}
+
+FOLLY_NOINLINE int func2_v1(int x) {
+  if (x > 1000) {
+    return func1_v1(x - 100);
+  }
+  return func1_v1(x + 100);
+}
+
+FOLLY_NOINLINE int func3_v1(int x) {
+  return func2_v1(x) ^ 0xCD;
+}
+} // namespace
+
+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_v1, iters) {
+  folly::BenchmarkSuspender susp;
+  using Serializer = CompactSerializer;
+  using Struct = LargeSetInt;
+  auto strct = create<Struct>();
+  folly::IOBufQueue q;
+  Serializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+
+  struct Node {
+    Node* next;
+    int value;
+  };
+  constexpr size_t kNumNodes = 16;
+  std::vector<Node> nodes(kNumNodes);
+  for (size_t i = 0; i < kNumNodes; ++i) {
+    nodes[i].next = &nodes[(i + 1) % kNumNodes];
+    nodes[i].value = i;
+  }
+  Node* current = &nodes[0];
+
+  susp.dismiss();
+  size_t s = 0;
+  while (iters--) {
+    auto obj = protocol::parseObject<GetReader<Serializer>>(*buf);
+    current = current->next;
+    s += current->value + func3_v1(obj->members.at(1).as_set().size());
+    folly::doNotOptimizeAway(obj);
+  }
+  susp.rehire();
+  folly::doNotOptimizeAway(s);
+}
+
 int main(int argc, char** argv) {
   folly::Init init(&argc, &argv);
   folly::runBenchmarks();
