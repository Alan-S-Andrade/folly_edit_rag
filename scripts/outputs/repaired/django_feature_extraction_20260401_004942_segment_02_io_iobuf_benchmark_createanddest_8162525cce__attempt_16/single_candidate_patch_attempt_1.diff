+// Helper function for createAndDestroyMulti_LargeAlloc to expand switch cases.
+// N ALU ops per case.
+__attribute__((noinline)) static int switch_case_large_1(const std::vector<uint64_t>& vec, uint64_t& current, uint64_t offset) {
+  int result = 0;
+  for (int i = 0; i < 14; ++i) { // Increased ops per case
+    result = (result * 17) ^ vec[(current + offset + i) & 0xFF];
+    result = (result + 23) ^ vec[(current - offset - i) & 0xFF];
+  }
+  return result & 0xFF;
+}
+
+__attribute__((noinline)) static int switch_case_large_2(const std::vector<uint64_t>& vec, uint64_t& current, uint64_t offset) {
+  int result = 0;
+  for (int i = 0; i < 14; ++i) { // Increased ops per case
+    result = (result + 29) ^ vec[(current + offset * 2 + i) & 0xFF];
+    result = (result ^ 31) + vec[(current - offset * 3 + i) & 0xFF];
+  }
+  return result & 0xFF;
+}
+
+__attribute__((noinline)) static int switch_case_large_3(const std::vector<uint64_t>& vec, uint64_t& current, uint64_t offset) {
+  int result = 0;
+  for (int i = 0; i < 14; ++i) { // Increased ops per case
+    result = (result ^ 37) + vec[(current + offset * 4 + i) & 0xFF];
+    result = (result * 41) ^ vec[(current - offset * 5 + i) & 0xFF];
+  }
+  return result & 0xFF;
+}
 } // namespace
 
