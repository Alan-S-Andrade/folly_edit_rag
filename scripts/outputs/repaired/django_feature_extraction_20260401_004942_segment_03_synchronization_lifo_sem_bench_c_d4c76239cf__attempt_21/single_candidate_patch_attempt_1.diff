+          // The original code had a bug here. It was masking `coldPos` and `coldPos->next`
+          // independently, which would result in undefined behavior if `coldMask` was 0.
+          // The correct way to conditionally update `coldPos` is to use the mask
+          // to select between `coldPos->next` and `coldPos` itself.
+          coldPos = (ChainNode*)((uintptr_t)coldPos->next * (coldMask != 0) |
+                                 (uintptr_t)coldPos * (coldMask == 0));
