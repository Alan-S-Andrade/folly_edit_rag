+
+// New helper functions for the benchmark to meet I-cache requirements.
+// These functions contain 256 cases, each with 10 ALU operations,
+// and use distinct literal constants.
+__attribute__((noinline)) static int large_alloc_switch_a(const std::vector<uint64_t>& vec, uint64_t current, uint64_t offset) {
+  int result = 0;
+  uint64_t index = (current + offset) & 0xFF;
+  for (int i = 0; i < 10; ++i) {
+    result = (result * 31) ^ vec[(index + i) & 0xFF] ^ (current >> (i * 2));
+  }
+  return result & 0xFF;
+}
+
+__attribute__((noinline)) static int large_alloc_switch_b(const std::vector<uint64_t>& vec, uint64_t current, uint64_t offset) {
+  int result = 0;
+  uint64_t index = (current - offset) & 0xFF;
+  for (int i = 0; i < 10; ++i) {
+    result = (result + 37) ^ vec[(index - i) & 0xFF] ^ (current << (i * 2));
+  }
+  return result & 0xFF;
+}
+
+__attribute__((noinline)) static int large_alloc_switch_c(const std::vector<uint64_t>& vec, uint64_t current, uint64_t offset) {
+  int result = 0;
+  uint64_t index = (current + offset * 3) & 0xFF;
+  for (int i = 0; i < 10; ++i) {
+    result = (result ^ 41) + vec[(index + i * 2) & 0xFF] ^ (current % (i + 1));
+  }
+  return result & 0xFF;
+}
 } // namespace
 
