+namespace {
+struct ChainNode {
+  ChainNode* next;
+  uint64_t payload;
+  char pad[48];
+};
+
+static constexpr size_t kHotLen = 16384; // 1MB
+static ChainNode hotNodes[kHotLen];
+static constexpr size_t kColdLen = 2u << 20; // 2M nodes, 128MB
+static ChainNode* coldNodes = nullptr;
+
+#define CASE(i, v) \
+  case i: \
+    v = (v + 0x12345 * i) * 0x6789a; \
+    v ^= (v >> 32); \
+    v = (v << (i & 7)) | (v >> (64 - (i & 7))); \
+    break
+
+#define CASES_16(i, v) \
+  CASE(i + 0, v); \
+  CASE(i + 1, v); \
+  CASE(i + 2, v); \
+  CASE(i + 3, v); \
+  CASE(i + 4, v); \
+  CASE(i + 5, v); \
+  CASE(i + 6, v); \
+  CASE(i + 7, v); \
+  CASE(i + 8, v); \
+  CASE(i + 9, v); \
+  CASE(i + 10, v); \
+  CASE(i + 11, v); \
+  CASE(i + 12, v); \
+  CASE(i + 13, v); \
+  CASE(i + 14, v); \
+  CASE(i + 15, v)
+
+#define CASES_256(v) \
+  CASES_16(0, v); \
+  CASES_16(16, v); \
+  CASES_16(32, v); \
+  CASES_16(48, v); \
+  CASES_16(64, v); \
+  CASES_16(80, v); \
+  CASES_16(96, v); \
+  CASES_16(112, v); \
+  CASES_16(128, v); \
+  CASES_16(144, v); \
+  CASES_16(160, v); \
+  CASES_16(176, v); \
+  CASES_16(192, v); \
+  CASES_16(208, v); \
+  CASES_16(224, v); \
+  CASES_16(240, v)
+
+__attribute__((noinline)) uint64_t switchA(uint64_t v, int c) {
+  switch (c & 0xFF) {
+    CASES_256(v);
+  }
+  return v;
+}
+__attribute__((noinline)) uint64_t switchB(uint64_t v, int c) {
+  switch (c & 0xFF) {
+    CASES_256(v);
+  }
+  return v;
+}
+__attribute__((noinline)) uint64_t switchC(uint64_t v, int c) {
+  switch (c & 0xFF) {
+    CASES_256(v);
+  }
+  return v;
+}
+
+static void initChain(ChainNode* nodes, size_t len) {
+  std::vector<size_t> perm(len);
+  std::iota(perm.begin(), perm.end(), 0u);
+  std::mt19937_64 rng(42);
+  std::shuffle(perm.begin(), perm.end(), rng);
+  for (size_t i = 0; i < len; ++i) {
+    nodes[perm[i]].next = &nodes[perm[(i + 1) % len]];
+    nodes[perm[i]].payload = (uint64_t)(uintptr_t)&nodes[perm[i]];
+  }
+}
+
+static std::once_flag init_flag;
+static void initialize_chains() {
+  std::call_once(init_flag, [] {
+    initChain(hotNodes, kHotLen);
+    coldNodes = new ChainNode[kColdLen];
+    initChain(coldNodes, kColdLen);
+  });
+}
