+static void contendedUse_v2(uint32_t n, int posters, int waiters) {
+  initialize_chains();
+  LifoSem sem;
+
+  std::vector<std::thread> threads;
+  std::atomic<bool> go(false);
+
+  BENCHMARK_SUSPEND {
+    for (int t = 0; t < waiters; ++t) {
+      threads.emplace_back([=, &sem] {
+        for (uint32_t i = t; i < n; i += waiters) {
+          sem.wait();
+        }
+      });
+    }
+    for (int t = 0; t < posters; ++t) {
+      threads.emplace_back([=, &sem, &go] {
+        while (!go.load()) {
+          std::this_thread::yield();
+        }
+
+        ChainNode* hotPos = &hotNodes[t * 123 % kHotLen];
+        ChainNode* coldPos = &coldNodes[t * 456 % kColdLen];
+        uint64_t acc = 0;
+        uint64_t iter_count = 0;
+
+        for (uint32_t i = t; i < n; i += posters) {
+          constexpr int kInnerIters = 16;
+          for (int j = 0; j < kInnerIters; ++j) {
+            hotPos = hotPos->next;
+            uint64_t payload = hotPos->payload;
+            switch (j % 3) {
+              case 0:
+                acc = switchA(acc, payload & 0xFF);
+                break;
+              case 1:
+                acc = switchB(acc, payload & 0xFF);
+                break;
+              case 2:
+                acc = switchC(acc, payload & 0xFF);
+                break;
+            }
+
+            auto coldMask = -uint64_t(iter_count % 128 == 0);
+            coldPos = (ChainNode*)((uintptr_t)coldPos->next & coldMask |
+                                   (uintptr_t)coldPos & ~coldMask);
+
+            iter_count++;
+          }
+          sem.post();
+        }
+        folly::doNotOptimizeAway(acc);
+        folly::doNotOptimizeAway(coldPos);
+      });
+    }
+  }
+
+  go.store(true);
+  for (auto& thr : threads) {
+    thr.join();
+  }
+}
+
 BENCHMARK_DRAW_LINE();
