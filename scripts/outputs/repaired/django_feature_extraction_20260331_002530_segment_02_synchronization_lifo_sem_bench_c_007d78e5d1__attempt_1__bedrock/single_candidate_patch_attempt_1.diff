+// switchD: a fourth noinline dispatch target with distinct arithmetic,
+// used only by contendedUse_v2 and contendedUse_hot to widen the hot
+// instruction footprint and reduce average dependency depth per iteration.
+__attribute__((noinline)) uint64_t switchD(uint64_t v, int c) {
+  switch (c & 0xFF) {
+    CASES_256(v, c * 7);
+    default:;
+  }
+  return v;
+}
