+BENCHMARK(SimpleJSONProtocol_read_UnorderedSetInt_v4, iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<UnorderedSetInt>();
+  const auto original_size = strct.int_set.size();
+  strct.int_set.clear();
+  // Using a multiplier to spread out hash values and reduce collisions.
+  for (size_t i = 0; i < original_size; ++i) {
+    strct.int_set.insert(i * 1031);
+  }
+
+  folly::IOBufQueue q;
+  SimpleJSONSerializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+  susp.dismiss();
+
+  while (iters--) {
+    UnorderedSetInt data;
+    SimpleJSONSerializer::deserialize(buf.get(), data);
+    folly::doNotOptimizeAway(data);
+  }
+  susp.rehire();
+}
+
