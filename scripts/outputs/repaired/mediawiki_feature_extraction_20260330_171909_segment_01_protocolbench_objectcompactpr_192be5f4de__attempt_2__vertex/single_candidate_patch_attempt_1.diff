+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_ipc_v1, iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<LargeSetInt>();
+  folly::IOBufQueue q;
+  CompactSerializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+
+  constexpr size_t chase_array_size = 16 * 1024;
+  std::vector<int> chase_values(chase_array_size);
+  std::vector<size_t> chase_indices(chase_array_size);
+  std::iota(chase_indices.begin(), chase_indices.end(), 0);
+
+  std::random_device rd;
+  std::mt19937 g(rd());
+  std::shuffle(chase_indices.begin(), chase_indices.end(), g);
+
+  std::vector<size_t> chase_next_idx(chase_array_size);
+  for (size_t i = 0; i < chase_array_size; ++i) {
+    chase_values[i] = (i * 2654435761u);
+    if (i < chase_array_size - 1) {
+      chase_next_idx[chase_indices[i]] = chase_indices[i + 1];
+    } else {
+      chase_next_idx[chase_indices[i]] = chase_indices[0];
+    }
+  }
+
+  size_t current_idx = 0;
+  int acc = 0;
+
+  susp.dismiss();
+
+  for (size_t i = 0; i < iters; ++i) {
+    auto obj = protocol::parseObject<GetReader<CompactSerializer>>(*buf);
+    folly::doNotOptimizeAway(obj);
+
+    for (int j = 0; j < 30; ++j) {
+      current_idx = chase_next_idx[current_idx];
+      int input = chase_values[current_idx];
+      switch (j % 3) {
+        case 0:
+          cpu_work_func1(input, acc);
+          break;
+        case 1:
+          cpu_work_func2(input, acc);
+          break;
+        case 2:
+          cpu_work_func3(input, acc);
+          break;
+      }
+    }
+  }
+
+  susp.rehire();
+  folly::doNotOptimizeAway(acc);
+}
