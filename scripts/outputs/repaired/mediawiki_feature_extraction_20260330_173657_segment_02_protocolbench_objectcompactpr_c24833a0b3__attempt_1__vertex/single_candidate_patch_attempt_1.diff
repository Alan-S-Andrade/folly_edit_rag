+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_IcachePressure, iters) {
+  folly::BenchmarkSuspender susp;
+  using Serializer = CompactSerializer;
+  using Struct = LargeSetInt;
+
+  auto strct = create<Struct>();
+  folly::IOBufQueue q;
+  Serializer::serialize(strct, &q);
+  auto buf = q.move();
+  buf->coalesce();
+
+  constexpr size_t kChaseSize = 256;
+  std::vector<uint8_t> chase(kChaseSize);
+  for (size_t i = 0; i < kChaseSize; ++i) {
+    chase[i] = i;
+  }
+  // Fisher-Yates shuffle
+  for (size_t i = kChaseSize - 1; i > 0; --i) {
+    using std::swap;
+    swap(chase[i], chase[folly::Random::rand32(i + 1)]);
+  }
+
+  uint8_t chase_idx = 0;
+  int64_t junk = 0;
+
+  susp.dismiss();
+
+  for (size_t i = 0; i < iters; ++i) {
+    auto obj = protocol::parseObject<GetReader<Serializer>>(*buf);
+    folly::doNotOptimizeAway(obj);
+
+    chase_idx = chase[chase_idx];
+
+    switch (i % 3) {
+      case 0:
+        junk = pbench_icache_1(junk, chase_idx);
+        break;
+      case 1:
+        junk = pbench_icache_2(junk, chase_idx);
+        break;
+      case 2:
+        junk = pbench_icache_3(junk, chase_idx);
+        break;
+    }
+  }
+  folly::doNotOptimizeAway(junk);
+  susp.rehire();
+}
