+// Variant: rotate across 6 noinline switch functions (vs 3 in v11) to widen
+// the hot instruction footprint and increase i-cache pressure, pushing IPC
+// down toward the target by stressing the frontend decode bandwidth.
+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_v12, iters) {
+  folly::BenchmarkSuspender susp;
+  constexpr size_t kSize = 1024 * 16;
+  struct Node {
+    Node* next;
+    char payload;
+  };
+  std::vector<Node> nodes(kSize);
+  for (size_t i = 0; i < kSize; ++i) {
+    nodes[i].next = &nodes[(i + 1) % kSize];
+    nodes[i].payload = (i * 53) & 0xFF;
+  }
+
+  Node* current = &nodes[0];
+  int acc = 0;
+  // 6-function rotation doubles the hot code footprint relative to v11,
+  // increasing L1i miss pressure and reducing IPC.
+  void (*funcs[])(int, int&) = {
+      switch_func_0,
+      switch_func_1,
+      switch_func_2,
+      switch_func_3,
+      switch_func_4,
+      switch_func_5,
+  };
+  susp.dismiss();
+
+  for (size_t i = 0; i < iters; ++i) {
+    current = current->next;
+    funcs[i % 6](current->payload, acc);
+  }
+
+  folly::doNotOptimizeAway(acc);
+  susp.rehire();
+}
+
