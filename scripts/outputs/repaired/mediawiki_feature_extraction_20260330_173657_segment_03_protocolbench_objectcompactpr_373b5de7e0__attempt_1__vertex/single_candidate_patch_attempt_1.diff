+BENCHMARK(ObjectCompactProtocol_read_LargeSetInt_ipc_v1, iters) {
+  folly::BenchmarkSuspender susp;
+  auto strct = create<LargeSetInt>();
+  folly::IOBufQueue q;
+  CompactSerializer::serialize(strct, &q);
+  auto buf = q.move();
+  // coalesce the IOBuf chain to test fast path
+  buf->coalesce();
+  susp.dismiss();
+
+  int j = 0;
+  while (iters--) {
+    auto obj = protocol::parseObject<GetReader<CompactSerializer>>(*buf);
+    folly::doNotOptimizeAway(obj);
+
+    for (int k = 0; k < 10; ++k) {
+      switch (j % 3) {
