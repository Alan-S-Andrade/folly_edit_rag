+static void contendedUse_v1(
+    uint32_t n, int posters, int waiters, int inner_iters) {
+  auto& s = *folly::Singleton<ChaseState>::get();
+  LifoSemImpl<std::atomic> sem;
+
+  std::vector<std::thread> threads;
+  std::atomic<bool> go(false);
+
+  BENCHMARK_SUSPEND {
+    for (int t = 0; t < waiters; ++t) {
+      threads.emplace_back([=, &sem, &s, &go] {
+        while (!go.load(std::memory_order_relaxed)) {
+          std::this_thread::yield();
+        }
+        size_t hot_start_offset = (t * 7919) % kHotLen;
+        size_t cold_start_offset = (t * 7919) % kColdLen;
+        ChainNode* hotPos = &s.hotNodes[hot_start_offset];
+        ChainNode* coldPos = &s.coldNodes[cold_start_offset];
+        uint64_t acc = 0;
+
+        for (uint32_t i = t; i < n; i += waiters) {
+          for (int j = 0; j < inner_iters; ++j) {
+            hotPos = hotPos->next;
+            uint64_t payload = (uint64_t)(uintptr_t)hotPos;
+            switch (j % 3) {
+              case 0:
+                acc = switchA(acc, payload & 0xFF);
+                break;
+              case 1:
+                acc = switchB(acc, payload & 0xFF);
+                break;
+              case 2:
+                acc = switchC(acc, payload & 0xFF);
+                break;
+            }
+            auto coldMask = -uint64_t(j % 8 == 0);
+            coldPos = (ChainNode*)((uintptr_t)coldPos->next & coldMask |
+                                   (uintptr_t)coldPos & ~coldMask);
+          }
+          sem.wait();
+        }
+        folly::doNotOptimizeAway(acc);
+      });
+    }
+    for (int t = 0; t < posters; ++t) {
+      threads.emplace_back([=, &sem, &go, &s] {
+        while (!go.load(std::memory_order_relaxed)) {
+          std::this_thread::yield();
+        }
+        size_t hot_start_offset = (t * 7919) % kHotLen;
+        size_t cold_start_offset = (t * 7919) % kColdLen;
+        ChainNode* hotPos = &s.hotNodes[hot_start_offset];
+        ChainNode* coldPos = &s.coldNodes[cold_start_offset];
+        uint64_t acc = 0;
+        for (uint32_t i = t; i < n; i += posters) {
+          for (int j = 0; j < inner_iters; ++j) {
+            hotPos = hotPos->next;
+            uint64_t payload = (uint64_t)(uintptr_t)hotPos;
+            switch (j % 3) {
+              case 0:
+                acc = switchA(acc, payload & 0xFF);
+                break;
+              case 1:
+                acc = switchB(acc, payload & 0xFF);
+                break;
+              case 2:
+                acc = switchC(acc, payload & 0xFF);
+                break;
+            }
+            auto coldMask = -uint64_t(j % 8 == 0);
+            coldPos = (ChainNode*)((uintptr_t)coldPos->next & coldMask |
+                                   (uintptr_t)coldPos & ~coldMask);
+          }
+          sem.post();
+        }
+        folly::doNotOptimizeAway(acc);
+      });
+    }
+  }
+
+  go.store(true);
+  for (auto& thr : threads) {
+    thr.join();
+  }
+}
