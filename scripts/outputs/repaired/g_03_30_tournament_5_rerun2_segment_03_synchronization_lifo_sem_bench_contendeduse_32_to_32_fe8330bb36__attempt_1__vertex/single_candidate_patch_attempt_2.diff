+struct ChainNode {
+  ChainNode* next;
+  char pad[64 - sizeof(ChainNode*)];
+};
+
+static constexpr size_t kHotLen = 16384; // 1MB
+static constexpr size_t kColdLen = 2 * 1024 * 1024; // 128MB
+
+#define GEN_CASE(i, salt1, salt2, op1, op2) \
+  case i:                                  \
+    v op1(i* salt1);                       \
+    v op2(i* salt2);                       \
+    break;
+#define GEN_CASES_8(i, salt1, salt2, op1, op2)    \
+  GEN_CASE(i, salt1, salt2, op1, op2)             \
+  GEN_CASE(i + 1, salt1, salt2, op1, op2)         \
+  GEN_CASE(i + 2, salt1, salt2, op1, op2)         \
+  GEN_CASE(i + 3, salt1, salt2, op1, op2)         \
+  GEN_CASE(i + 4, salt1, salt2, op1, op2)         \
+  GEN_CASE(i + 5, salt1, salt2, op1, op2)         \
+  GEN_CASE(i + 6, salt1, salt2, op1, op2)         \
+  GEN_CASE(i + 7, salt1, salt2, op1, op2)
+#define GEN_CASES_32(i, salt1, salt2, op1, op2)   \
+  GEN_CASES_8(i, salt1, salt2, op1, op2)          \
+  GEN_CASES_8(i + 8, salt1, salt2, op1, op2)      \
+  GEN_CASES_8(i + 16, salt1, salt2, op1, op2)     \
+  GEN_CASES_8(i + 24, salt1, salt2, op1, op2)
+#define GEN_CASES_256(salt1, salt2, op1, op2)     \
+  GEN_CASES_32(0, salt1, salt2, op1, op2)         \
+  GEN_CASES_32(32, salt1, salt2, op1, op2)        \
+  GEN_CASES_32(64, salt1, salt2, op1, op2)        \
+  GEN_CASES_32(96, salt1, salt2, op1, op2)        \
+  GEN_CASES_32(128, salt1, salt2, op1, op2)       \
+  GEN_CASES_32(160, salt1, salt2, op1, op2)       \
+  GEN_CASES_32(192, salt1, salt2, op1, op2)       \
+  GEN_CASES_32(224, salt1, salt2, op1, op2)
+
+__attribute__((noinline)) uint64_t switchA(uint64_t v, int c) {
+  switch (c) {
+    GEN_CASES_256(13, 17, +=, ^=)
+    default:
+      break;
+  }
+  return v;
+}
+
+__attribute__((noinline)) uint64_t switchB(uint64_t v, int c) {
+  switch (c) {
+    GEN_CASES_256(19, 23, -=, |=)
+    default:
+      break;
+  }
+  return v;
+}
+
+__attribute__((noinline)) uint64_t switchC(uint64_t v, int c) {
+  switch (c) {
+    GEN_CASES_256(29, 31, ^=, +=)
+    default:
+      break;
+  }
+  return v;
+}
+
+struct ChaseState {
+  std::unique_ptr<ChainNode[]> hotNodes;
+  std::unique_ptr<ChainNode[]> coldNodes;
+
+  ChaseState()
+      : hotNodes(new ChainNode[kHotLen]), coldNodes(new ChainNode[kColdLen]) {
+    initChain(hotNodes.get(), kHotLen);
+    initChain(coldNodes.get(), kColdLen);
+  }
+
+  static void initChain(ChainNode* nodes, size_t len) {
+    std::vector<size_t> perm(len);
+    std::iota(perm.begin(), perm.end(), 0u);
+    std::mt19937_64 rng(42);
+    for (size_t i = len - 1; i > 0; --i) {
+      std::swap(perm[i], perm[rng() % (i + 1)]);
+    }
+    for (size_t i = 0; i < len; ++i) {
+      nodes[perm[i]].next = &nodes[perm[(i + 1) % len]];
+    }
+  }
+};
+
+} // namespace
 
